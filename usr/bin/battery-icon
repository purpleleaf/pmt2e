#!/bin/sh

# This script displays battery icon according to the charge level and charging state

# Author: Piotr Miller <nwg.piotr@gmail.com>
# Author: purpleleaf <max@ganoia.eu>
# Website: http://nwg.pl
# Project: https://github.com/purpleleaf/pmt2e
# License: GPL3

# Dependencies: acpi ogg123 (vorbis-tools) dunst yad
# Note: On Arch Linux, these should be handled by the PKGBUILD. 
# If installing manually on other distros, please ensure they are installed.

scriptname=$(basename "$0")
action=""

# Centralized YAD dialog function - Optimized for Window Managers like Muffin/Cinnamon
show_dialog() {
    msg_text="$1"
    msg_title="${2:-Message}"
    msg_icon="${3:-dialog-information}"

    yad --title="$msg_title" \
        --text="$msg_text" \
        --image="$msg_icon" \
        --window-icon="$msg_icon" \
        --button="Close:0"
}

# POSIX-compliant binary check
exists() {
    command -v "$1" >/dev/null 2>&1
}

# Universal error handler. Use -g for GUI popup.
die() {
    gui=false
    if [ "$1" = "-g" ]; then
        gui=true
        shift
    fi

    if [ "$gui" = "true" ] && exists yad; then
        show_dialog "$*" "Error" "dialog-error"
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

show_help () {
  printf -- "\nUsage: %s [ -h | -n | -m | -t | -f | -i | -d | -a ]\n\n" "$scriptname"
  printf -- "  -h, Show this help message and exit.\n"
  printf -- "  -n, Show notification.\n"
  printf -- "  -m, Show jgmenu.\n"
  printf -- "  -t, show only text as tint2 executor output.\n"
  printf -- "  -f, show a font gyph as tint2 executor output.\n"
  printf -- "  -i, show an icon as tint2 executor output.\n"
  printf -- "  -d, show battery details dialog.\n"
  printf -- "  -a, show about dialog.\n\n"
  printf -- "If multiple arguments are provided, only the first one will be considered\n\n"
  exit 0    
}

while getopts ":nhmtfida" opt; do
  case ${opt} in
    h) [ -n "$action" ] && die "Only one action can be chosen."; action=help ;;
    n) [ -n "$action" ] && die "Only one action can be chosen."; action=notification ;;
    t) [ -n "$action" ] && die "Only one action can be chosen."; action=text ;;
    f) [ -n "$action" ] && die "Only one action can be chosen."; action=glyph ;;
    i) [ -n "$action" ] && die "Only one action can be chosen."; action=icon ;;
    m) [ -n "$action" ] && die "Only one action can be chosen."; action=menu ;;
    d) [ -n "$action" ] && die "Only one action can be chosen."; action=details ;;
    a) [ -n "$action" ] && die "Only one action can be chosen."; action=about ;;
    *) die "Invalid option -${OPTARG}" ;;
  esac
done

# exit if $action is not set
if [ -z "$action" ]; then
  die "$scriptname requires an option: [-h | -n | -m | -t | -f | -i | -d | -a]. \
Please run \"$scriptname -h\" for usage."
fi

# Silently ignore errors if acpi is entirely missing
bat=$(acpi -b 2>/dev/null)

if [ -n "$bat" ]; then
    # tr -s ' ' squeezes multiple spaces to one, cut extracts the Nth field
    state=$(echo "$bat" | tr -s ' ' | cut -d ' ' -f 3)

    if [ "$state" = "Not" ]; then
        level=$(echo "$bat" | tr -s ' ' | cut -d ' ' -f 5)
        level=${level%?} 
    else
        level=$(echo "$bat" | tr -s ' ' | cut -d ' ' -f 4)
        case "$state" in
            *Unknown*)
                level=${level%?}
                ;;
            *)
                if [ "$level" = "100%" ]; then
                  level=${level%?}
                else
                  level=${level%??}
                fi
                ;;
        esac
    fi
fi

get_icon(){
  # Handle the No Battery edge case
  if [ -z "$bat" ]; then
      echo /usr/share/pmt2e/icons/bat-unknown.svg
      return
  fi

  case "$bat" in
      *until*)
          if [ "$level" -ge 95 ]; then echo /usr/share/pmt2e/icons/bat-full-charging.svg
          elif [ "$level" -ge 75 ]; then echo /usr/share/pmt2e/icons/bat-threefourth-charging.svg
          elif [ "$level" -ge 35 ]; then echo /usr/share/pmt2e/icons/bat-half-charging.svg
          elif [ "$level" -ge 15 ]; then echo /usr/share/pmt2e/icons/bat-quarter-charging.svg
          else echo /usr/share/pmt2e/icons/bat-empty-charging.svg
          fi
          ;;
      *)
          if [ "$level" -ge 95 ]; then echo /usr/share/pmt2e/icons/bat-full.svg
          elif [ "$level" -ge 75 ]; then echo /usr/share/pmt2e/icons/bat-threefourth.svg
          elif [ "$level" -ge 35 ]; then echo /usr/share/pmt2e/icons/bat-half.svg
          elif [ "$level" -ge 15 ]; then echo /usr/share/pmt2e/icons/bat-quarter.svg
          else
              if [ "$level" -le 5 ]; then
                  ogg123 -q /usr/share/sounds/freedesktop/stereo/bell.oga >/dev/null 2>&1
                  dunstify -t 5000 -h string:x-dunst-stack-tag:battery -u critical "$bat" >/dev/null 2>&1
              fi
              echo /usr/share/pmt2e/icons/bat-empty.svg
          fi
          ;;
  esac
}

get_glyph(){
  # Handle the No Battery edge case
  if [ -z "$bat" ]; then
      echo "󰂑"
      return
  fi

  case "$bat" in
      *until*|*"Not charging"*|*Full*)
          if [ "$level" -eq 100 ]; then echo "󰂅"
          elif [ "$level" -ge 90 ]; then echo "󰂋"
          elif [ "$level" -ge 80 ]; then echo "󰂊"
          elif [ "$level" -ge 70 ]; then echo "󰢞"
          elif [ "$level" -ge 60 ]; then echo "󰂉"
          elif [ "$level" -ge 50 ]; then echo "󰢝"
          elif [ "$level" -ge 40 ]; then echo "󰂈"
          elif [ "$level" -ge 30 ]; then echo "󰂇"
          elif [ "$level" -ge 20 ]; then echo "󰂆"
          elif [ "$level" -ge 10 ]; then echo "󰢜"
          else echo "󰢟"
          fi
          ;;
      *)
          if [ "$level" -eq 100 ]; then echo "󰁹"
          elif [ "$level" -ge 90 ]; then echo "󰂂"
          elif [ "$level" -ge 80 ]; then echo "󰂁"
          elif [ "$level" -ge 70 ]; then echo "󰂀"
          elif [ "$level" -ge 60 ]; then echo "󰁿"
          elif [ "$level" -ge 50 ]; then echo "󰁾"
          elif [ "$level" -ge 40 ]; then echo "󰁽"
          elif [ "$level" -ge 30 ]; then echo "󰁼"
          elif [ "$level" -ge 20 ]; then echo "󰁻"
          elif [ "$level" -ge 10 ]; then echo "󰁺"
          else
              if [ "$level" -le 5 ]; then
                  ogg123 -q /usr/share/sounds/freedesktop/stereo/bell.oga >/dev/null 2>&1
                  dunstify -t 5000 -h string:x-dunst-stack-tag:battery -u critical "$bat" >/dev/null 2>&1
              fi
              echo "󰂎"
          fi
          ;;
  esac
}

case ${action} in
  help)
    show_help
    ;;
  
  details)
    [ -z "$bat" ] && die -g "No battery detected on this system."

    time_info=$(echo "$bat" | cut -d ',' -f 3)
    time_info=${time_info# }
    
    state_clean=${state%,}
    [ -z "$state_clean" ] && state_clean="Unknown"
    
    health="Unknown"
    cycles="Unknown"
    vendor="Unknown"
    model="Unknown"
    
    bat_dir=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -n 1)
    
    if [ -n "$bat_dir" ]; then
        if [ -f "$bat_dir/energy_full" ]; then
            full=$(cat "$bat_dir/energy_full")
            design=$(cat "$bat_dir/energy_full_design")
        elif [ -f "$bat_dir/charge_full" ]; then
            full=$(cat "$bat_dir/charge_full")
            design=$(cat "$bat_dir/charge_full_design")
        fi
        
        if [ -n "$full" ] && [ -n "$design" ] && [ "$design" -gt 0 ]; then
            health=$(( (full * 100) / design ))"%"
        fi
        
        if [ -f "$bat_dir/cycle_count" ]; then
            cycles=$(cat "$bat_dir/cycle_count")
            [ "$cycles" = "0" ] && cycles="Not Supported by Hardware"
        fi
        
        [ -f "$bat_dir/manufacturer" ] && vendor=$(cat "$bat_dir/manufacturer")
        [ -f "$bat_dir/model_name" ] && model=$(cat "$bat_dir/model_name")
    fi

    yad_text="<b>Current Status</b>\n"
    yad_text="${yad_text}State: ${state_clean}\n"
    yad_text="${yad_text}Charge Level: ${level}%\n"
    if [ -n "$time_info" ]; then
        yad_text="${yad_text}Time: ${time_info}\n"
    fi
    
    yad_text="${yad_text}\n<b>Battery Health</b>\n"
    yad_text="${yad_text}Capacity: ${health} (vs brand new)\n"
    yad_text="${yad_text}Charge Cycles: ${cycles}\n"

    if [ "$vendor" != "Unknown" ] || [ "$model" != "Unknown" ]; then
        yad_text="${yad_text}\n<b>Hardware Info</b>\n"
        yad_text="${yad_text}Vendor: ${vendor}\n"
        yad_text="${yad_text}Model: ${model}\n"
    fi

    show_dialog "$yad_text" "Battery Details" "battery"
    ;;

  about)
    about_text="PMT2e - Poor Man Tint2 executors\n\nBash scripts to add some useful executors to Tint2 panel.\n\nAuthor: purpleaf"
    show_dialog "$about_text" "About PMT2e" "gtk-about"
    ;;

  menu)
    menu_list=$(
        printf "Battery Details,%s -d\n" "$scriptname"
        printf "^sep()\n"
        printf "About,%s -a\n" "$scriptname"
    )
    printf '%s\n' "$menu_list" | createjgmenu
    ;;
  
  notification)
    [ -z "$bat" ] && exit 0
    
    if [ "$level" -le 5 ]; then
        case "$bat" in
            *until*) dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u normal "$bat" ;;
            *) dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u critical "$bat" ;;
        esac
    else
        dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u normal "$bat"
    fi
    ;;
  
  text)
    if [ -z "$bat" ]; then
        echo "Bat: N/A"
    else
        echo "Bat: ${level}%"
    fi
    ;;
  
  glyph)
    get_glyph
    ;;
  
  icon)
    get_icon
    ;;
esac#!/bin/sh

# This script displays battery icon according to the charge level and charging state

# Author: Piotr Miller <nwg.piotr@gmail.com>
# Author: purpleleaf <max@ganoia.eu>
# Website: http://nwg.pl
# Project: https://github.com/purpleleaf/pmt2e
# License: GPL3

# Dependencies: acpi ogg123 (vorbis-tools) dunst

scriptname=`basename $0`
die() { echo "$*" 1>&2 ; exit 1; }
action=""

show_help () {
  printf -- "\nUsage: $scriptname [ -h | -n | -m | -t | -f | -i ]\n"
  printf -- "\n"
  printf -- "  -h, Show this help message and exit.\n"
  printf -- "  -n, Show notification.\n"
  printf -- "  -m, Show jgmenu.\n"
  printf -- "  -t, show only text as tint2 executor output.\n"
  printf -- "  -f, show a font gyph as tint2 executor output.\n"
  printf -- "  -i, show an icon as tint2 executor output.\n\n"
  printf -- "If multiple arguments are provided, only the first one will considered\n\n"
  exit 0	
}

while getopts ":nhmtfi" opt; do
  case ${opt} in
    h)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
	  action=help
      ;;
    n)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
	  action=notification
      ;;
    t)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
      action=text
      ;;
    f)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
      action=glyph
      ;;
    i)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
      action=icon
      ;;
    m)
      [ -n "$action" ] && die "Only one action can be chosen between -h -n -m -t -f -i"
	  action=menu
      ;;
    *)
      die "Invalid option -"$OPTARG""
      ;;
  esac
done

# exit if $action and/or $output are not set
if [[ ! -n "$action" ]]; then
die "$scriptname requires an option: [-h | -n | -m | -t | -f | -i]. \
Please run \"$scriptname -h\" for usage."
fi

if [[ ${show_menu} == "true" ]]; then
    createjgmenu 'About, sh -c  $(yad --image="gtk-about" --on-top --button="yad-ok:0" --center --text="PMT2e - Poor Man Tint2 executors\n\nBash scripts to add some useful \"executors\" to Tint2 panel.\n\nAuthor: purpleaf")'
    exit
fi

bat=$(acpi -b)

if [[ $bat ]]; then
    state=$(echo ${bat} | awk '{print $3}')

    if [[ "$state" = "Not" ]]; then
        level=$(echo ${bat} | awk '{print $5}')
        level=${level::-1}

    else
        level=$(echo ${bat} | awk '{print $4}')
        if [[ "$state" == *"Unknown"* ]]; then
            level=${level::-1}
        else
            if [[ "$level" == "100%" ]]; then
              level=${level::-1}
            else
              level=${level::-2}
            fi
        fi
    fi
fi

get_icon(){
if [[ "$bat" == *"until"* ]]; then
	if [[ "$level" -ge "95" ]]; then
		echo /usr/share/pmt2e/icons/bat-full-charging.svg
	elif [[ "$level" -ge "75" ]]; then
		echo /usr/share/pmt2e/icons/bat-threefourth-charging.svg
	elif [[ "$level" -ge "35" ]]; then
		echo /usr/share/pmt2e/icons/bat-half-charging.svg
	elif [[ "$level" -ge "15" ]]; then
		echo /usr/share/pmt2e/icons/bat-quarter-charging.svg
	else
		echo /usr/share/pmt2e/icons/bat-empty-charging.svg
	fi
else
	if [[ "$level" -ge "95" ]]; then
		echo /usr/share/pmt2e/icons/bat-full.svg
	elif [[ "$level" -ge "75" ]]; then
		echo /usr/share/pmt2e/icons/bat-threefourth.svg
	elif [[ "$level" -ge "35" ]]; then
		echo /usr/share/pmt2e/icons/bat-half.svg
	elif [[ "$level" -ge "15" ]]; then
		echo /usr/share/pmt2e/icons/bat-quarter.svg
	else
		if [[ "$level" -le "5" ]]; then
			ogg123 -q /usr/share/sounds/freedesktop/stereo/bell.oga
			dunstify -t 5000 -h string:x-dunst-stack-tag:battery -u critical "$bat"
		fi
		echo /usr/share/pmt2e/icons/bat-empty.svg
	fi
fi
if [[ $2 == "-l" ]]; then
	echo ${level}%
fi
}

get_glyph(){
if [[ "$bat" == *"until"* ]] || [[ "$bat" == *"Not charging"* ]] || [[ "$bat" == *"Full"* ]] ; then
	if [[ "$level" -eq "100" ]]; then
		echo "󰂅"
	elif [[ "$level" -ge "90" ]]; then
		echo "󰂋"
	elif [[ "$level" -ge "80" ]]; then
		echo "󰂊"
	elif [[ "$level" -ge "70" ]]; then
		echo "󰢞"
	elif [[ "$level" -ge "60" ]]; then
		echo "󰂉"
	elif [[ "$level" -ge "50" ]]; then
		echo "󰢝"
	elif [[ "$level" -ge "40" ]]; then
		echo "󰂈"
	elif [[ "$level" -ge "30" ]]; then
		echo "󰂇"
	elif [[ "$level" -ge "20" ]]; then
		echo "󰂆"
	elif [[ "$level" -ge "10" ]]; then
		echo "󰢜"
	else
		echo "󰢟"
	fi
else
	if [[ "$level" -eq "100" ]]; then
		echo "󰁹"
	elif [[ "$level" -ge "90" ]]; then
		echo "󰂂"
	elif [[ "$level" -ge "80" ]]; then
		echo "󰂁"
	elif [[ "$level" -ge "70" ]]; then
		echo "󰂀"
	elif [[ "$level" -ge "60" ]]; then
		echo "󰁿"
	elif [[ "$level" -ge "50" ]]; then
		echo "󰁾"
	elif [[ "$level" -ge "40" ]]; then
		echo "󰁽"
	elif [[ "$level" -ge "30" ]]; then
		echo "󰁼"
	elif [[ "$level" -ge "20" ]]; then
		echo "󰁻"
	elif [[ "$level" -ge "10" ]]; then
		echo "󰁺"
	else
		if [[ "$level" -le "5" ]]; then
			ogg123 -q /usr/share/sounds/freedesktop/stereo/bell.oga
			dunstify -t 5000 -h string:x-dunst-stack-tag:battery -u critical "$bat"
		fi
		echo "󰂎"
	fi
fi
}

case ${action} in
  help)
    show_help
echo pippo
    ;;
  menu)
    createjgmenu 'About, sh -c  $(yad --image="gtk-about" --on-top --button="yad-ok:0" --center --text="PMT2e - Poor Man Tint2 executors\n\nBash scripts to add some useful \"executors\" to Tint2 panel.\n\nAuthor: purpleaf")'
    ;;
  notification)
	if [[ "$level" -le "5" ]]; then
		if [[ "$bat" == *"until"* ]]; then
		  dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u normal "$bat"
        else
          dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u critical "$bat"
		fi
	else
		dunstify -t 2500 -h string:x-dunst-stack-tag:battery -u normal "$bat"
	fi
    ;;
  text)
	echo "Bat: ${level}%"
    ;;
  glyph)
    get_glyph
    ;;
  icon)
    get_icon
    ;;
esac
