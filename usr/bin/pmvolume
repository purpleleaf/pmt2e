#!/bin/sh
# ==============================================================================
# Script Name  : pmvolume
# Description  : PMT2e Volume Executor - ALSA monitor with flood protection
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : alsa-utils, yad, jgmenu, pmgui-scale (external)
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")
lock_file="/tmp/${scriptname}.lock"

# ---------------------------------------------------------
# Error handling & Utilities
# ---------------------------------------------------------
exists() { command -v "$1" >/dev/null 2>&1; }

show_dialog() {
    [ -f "$lock_file" ] && return
    touch "$lock_file"
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
    rm -f "$lock_file"
}

die() {
    if [ "$1" = "-y" ]; then
        shift
        if exists yad; then show_dialog "$*" "Volume Error" "dialog-error"
        else printf '%s\n' "$*" 1>&2; fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

# --- Configuration Load ---
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmvolume.conf"

mixer_channel="Auto"
vol_step=5
waybar_signal="9"
sfwbar_signal="5"

if [ -f "$config_file" ] && [ -r "$config_file" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
        val="${val%\"}"; val="${val#\"}"; val="${val%\'}"; val="${val#\'}"
        case "$key" in
            mixer_channel) mixer_channel="$val" ;;
            vol_step)      vol_step="$val" ;;
            waybar_signal) waybar_signal="$val" ;;
            sfwbar_signal) sfwbar_signal="$val" ;;
        esac
    done < "$config_file"
fi

# ---------------------------------------------------------
# ALSA Logic
# ---------------------------------------------------------
get_channel() {
    if [ "$mixer_channel" = "Auto" ]; then
        mixer_channel=$(amixer scontrols | sed -n "s/.*'\(.*\)'.*/\1/p" | head -n1)
    fi
    [ -n "$mixer_channel" ] || die -y "No ALSA control found. Check your soundcard settings."
}

get_volume() {
    status=$(amixer get "$mixer_channel" 2>/dev/null)
    [ $? -ne 0 ] && return 1
    
    # POSIX safe parsing using tr to remove noise and extract only the number
    vol=$(printf '%s\n' "$status" | grep -m1 "[%]" | tr -d '[]%,' | awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+$/) {print $i; break}}')
    
    if printf '%s\n' "$status" | grep -q "\[off\]"; then 
        state="off"
    else 
        state="on"
    fi
}

send_notification() {
    exists dunstify || return
    if [ "$state" = "off" ]; then
        dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i audio-volume-muted-symbolic "Volume Muted"
    else
        [ "$vol" -ge 70 ] && icon="audio-volume-high-symbolic" || ([ "$vol" -ge 30 ] && icon="audio-volume-medium-symbolic" || icon="audio-volume-low-symbolic")
        dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i "$icon" -h int:value:"$vol" "Volume: ${vol}%"
    fi
}

broadcast_refresh() {
    pgrep -x waybar >/dev/null && pkill -RTMIN+"$waybar_signal" waybar
    pgrep -x sfwbar >/dev/null && pkill -RTMIN+"$sfwbar_signal" sfwbar
}

# ---------------------------------------------------------
# Execution
# ---------------------------------------------------------
get_channel
action=""
output_format=""
[ $# -eq 0 ] && output_format="text"

while getopts ":huxdms:iftg" opt; do
    case ${opt} in
        h) cat <<EOF
Usage: $scriptname [Action] | [Output]
Actions: -u (up), -d (down), -x (mute), -s [0-100] (set), -m (menu), -g (gui)
Outputs: -t (text), -f (glyph), -i (icon)
EOF
           exit 0 ;;
        u) action="up" ;;
        d) action="down" ;;
        x) action="mute" ;;
        s) action="set"; input_vol="$OPTARG" ;;
        g) pmgui-scale -v; exit 0 ;;
        m) action="menu" ;;
        i) output_format="icon" ;;
        f) output_format="glyph" ;;
        t) output_format="text" ;;
    esac
done

if [ -n "$action" ]; then
    case "$action" in
        up)   amixer sset "$mixer_channel" "${vol_step}%+" >/dev/null ;;
        down) amixer sset "$mixer_channel" "${vol_step}%-" >/dev/null ;;
        mute) amixer sset "$mixer_channel" toggle >/dev/null ;;
        set)  amixer sset "$mixer_channel" "${input_vol}%" >/dev/null ;;
        menu) printf "Volume GUI,pmgui-scale -v\nMixer,xterm -e alsamixer\n" | createjgmenu; exit 0 ;;
    esac
    get_volume; send_notification; broadcast_refresh
    [ -z "$output_format" ] && exit 0
fi

if [ -n "$output_format" ]; then
    get_volume
    if [ $? -ne 0 ]; then
        case "$output_format" in
            text)  echo "Vol: N/A" ;;
            glyph) echo "󰝟" ;;
            icon)  echo "audio-volume-muted-symbolic" ;;
        esac
        exit 0
    fi

    if [ "$state" = "off" ]; then
        case "$output_format" in
            text)  echo "Muted" ;;
            glyph) echo "󰝟" ;;
            icon)  echo "audio-volume-muted-symbolic" ;;
        esac
    else
        case "$output_format" in
            text)  echo "${vol}%" ;;
            glyph) [ "$vol" -ge 66 ] && echo "󰕾" || ([ "$vol" -ge 33 ] && echo "󰖀" || echo "󰕿") ;;
            icon)  [ "$vol" -ge 70 ] && echo "audio-volume-high-symbolic" || echo "audio-volume-low-symbolic" ;;
        esac
    fi
fi#!/bin/sh
# ==============================================================================
# Script Name  : pmvolume
# Description  : PMT2e Volume Executor - A lightweight ALSA volume monitor
# Author       : Max Franco <purpleleaf at ganoia.eu>
# Credits      : Piotr Miller (nwg-piotr) - Original creator of the t2ec project
# License      : GPL-3.0
# Dependencies : alsa-utils (amixer), yad, jgmenu, dunstify (optional)
# ==============================================================================

# --- Utility Functions ---
exists() {
    command -v "$1" >/dev/null 2>&1
}

show_dialog() {
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
}

die() {
    if [ "$1" = "-g" ]; then
        shift
        if exists yad; then
            show_dialog "$*" "Error" "dialog-error"
        else
            printf '%s\n' "$*" 1>&2
        fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

# --- Configuration & Terminal Detection ---
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmvolume.conf"

terminal_list="xterm $TERMINAL x-terminal-emulator alacritty kitty foot ghostty urxvt rxvt st qterminal gnome-terminal xfce4-terminal mate-terminal terminology"

terminal=""
for term in $terminal_list; do
    if exists "$term"; then terminal="$term"; break; fi
done

# Default Configuration
mixer_channel="Auto"
vol_step=5
mixer_app="alsamixer"
mixer_type="CLI"
waybar_signal="9"
sfwbar_signal="5"

if [ -f "$config_file" ] && [ -r "$config_file" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        case "$key" in
            mixer_channel) mixer_channel="$val" ;;
            vol_step)      vol_step="$val" ;;
            mixer_app)     mixer_app="$val" ;;
            mixer_type)    mixer_type="$val" ;;
            terminal)      terminal="$val" ;;
            term_emu)      terminal="$val" ;; # Legacy support
            waybar_signal) waybar_signal="$val" ;;
            sfwbar_signal) sfwbar_signal="$val" ;;
        esac
    done < "$config_file"
fi

# --- Global Variables ---
scriptname=$(basename "$0")
action="text" # Default action if no arguments are passed
input_vol=""

show_help() {
    cat << EOF
Usage: $scriptname [OPTION]

PMT2e Volume Executor - A lightweight ALSA volume monitor for panels.
Defaults to '-t' (text output) if no options are provided.

Options:
  -t      Print volume text (e.g., 50% or Muted)
  -i      Print the path to the current volume icon (SVG)
  -f      Print the volume Nerd Font glyph
  -u      Increase volume by the configured step
  -d      Decrease volume by the configured step
  -x      Toggle mute state
  -s NUM  Set volume to specific number (0-100)
  -m      Generate jgmenu formatted output for context menus
  -M      Open the configured audio mixer
  -S      Open the default sound card selector
  -c      Open the configuration GUI
  -h      Show this help message and exit
EOF
}

# --- ALSA Parsing (BusyBox/BSD Compatible) ---

get_channel() {
    if [ "$mixer_channel" = "Auto" ] || [ -z "$mixer_channel" ]; then
        mixer_channel=$(
            amixer scontrols |
            while IFS= read -r ctl; do
                case "$ctl" in
                    *"'"*"'"*)
                        name=$(printf '%s\n' "$ctl" | sed "s/.*'\(.*\)'.*/\1/")
                        if amixer get "$name" | grep -q '%'; then
                            printf '%s\n' "$name"
                            break
                        fi
                        ;;
                esac
            done
        )
    fi
    [ -n "$mixer_channel" ] || die -g "No volume control available on this device."
}

get_volume() {
    vol_out=$(
        amixer get "$mixer_channel" |
        while IFS= read -r line; do
            case "$line" in
                *%*)
                    set -- $(printf '%s\n' "$line" | tr '[]' ' ')
                    for field in "$@"; do
                        case "$field" in
                            *%)
                                printf '%s\n' "${field%\%}"
                                return 0
                                ;;
                        esac
                    done
                    ;;
            esac
        done
    )

    case "$vol_out" in
        ''|*[!0-9]*) die -g "Failed to read numeric volume from control: $mixer_channel" ;;
        *) vol="$vol_out" ;;
    esac

    if amixer get "$mixer_channel" | grep '%' | grep -q off; then
        state="off"
    else
        state="on"
    fi
}

# --- Notification Logic ---

send_notification() {
    if exists dunstify; then
        if [ "$state" = "off" ]; then
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i audio-volume-muted-symbolic -u normal "Volume Muted"
        else
            if [ "$vol" -ge 70 ]; then icon="audio-volume-high-symbolic"
            elif [ "$vol" -ge 30 ]; then icon="audio-volume-medium-symbolic"
            else icon="audio-volume-low-symbolic"
            fi
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i "$icon" -h int:value:"$vol" -u normal "Volume: ${vol}%"
        fi
    fi
}

broadcast_refresh() {
    if pgrep -x "waybar" >/dev/null; then pkill -RTMIN+"$waybar_signal" waybar; fi
    if pgrep -x "sfwbar" >/dev/null; then pkill -RTMIN+"$sfwbar_signal" sfwbar; fi
}

# --- Main Logic / Argument Parsing ---

if [ $# -gt 0 ]; then
    action=""
    while getopts ":StfhiudxmMcs:" opt; do
        case ${opt} in
            S) action=select_card ;;
            t) action=text ;;
            f) action=glyph ;;
            i) action=icon ;;
            u) action=vol_up ;;
            d) action=vol_down ;;
            x) action=mute_toggle ;;
            m) action=menu ;;
            M) action=open_mixer ;;
            c) action=config ;;
            s)
                action=set_vol
                case "$OPTARG" in
                    ''|*[!0-9]*) die "Error: -s argument must be a number 0-100" ;;
                    *) [ "$OPTARG" -ge 0 ] && [ "$OPTARG" -le 100 ] && input_vol="$OPTARG" || die "Error: -s must be 0-100" ;;
                esac
                ;;
            h) show_help; exit 0 ;;
            :)
                printf "%s: option -%s requires an argument (0-100).\n" "$scriptname" "$OPTARG" >&2
                exit 1
                ;;
            \?|*)
                printf "%s: unrecognised option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
                exit 1
                ;;
        esac
    done
fi

if [ -z "$action" ]; then
    printf "%s: missing valid option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
    exit 1
fi

exists amixer || die -g "amixer not found; ALSA tools required."

# Bypass ALSA volume querying if we are just opening a GUI
case $action in
    config|help|select_card) ;;
    *) get_channel; get_volume ;;
esac

# --- Action Execution ---

case ${action} in
    config)
        mkdir -p "$config_dir"

        while true; do
            # Build ALSA dropdown
            combo_list="$mixer_channel"
            [ "$mixer_channel" != "Auto" ] && combo_list="${combo_list}!Auto"

            extra_controls=$(amixer scontrols 2>/dev/null | sed -n "s/.*'\(.*\)'.*/\1/p" | while read -r c; do
                [ "$c" != "$mixer_channel" ] && printf "!%s" "$c"
            done)
            combo_list="${combo_list}${extra_controls}"

            if [ "$mixer_type" = "GUI" ]; then type_combo="GUI!CLI"
            else type_combo="CLI!GUI"; fi

            new_configs=$(yad --title="PM Volume configuration" \
                --window-icon="multimedia-volume-control" \
                --form \
                --columns=2 \
                --field="ALSA Channel:":CB "$combo_list" \
                --field="Volume Step (%):NUM" "$vol_step"'!1..100!1!0' \
                --field="Mixer App:" "$mixer_app" \
                --field="Mixer Type:":CB "$type_combo" \
                --field="Terminal Emulator:" "$terminal" \
                --field='!gtk-help!ALSA Channel':BTN "yad --info --title='Info' --borders=15 --text='Select the ALSA control. Auto will attempt to find the default volume slider.'" \
                --field='!gtk-help!Volume Step Size':BTN "yad --info --title='Info' --borders=15 --text='How much the volume changes when using the up/down commands.'" \
                --field='!gtk-help!Mixer App':BTN "yad --info --title='Info' --borders=15 --text='Type the mixer command to launch (e.g., alsamixer, qasmixer).'" \
                --field='!gtk-help!Mixer Type':BTN "yad --info --title='Info' --borders=15 --text='Select CLI for terminal apps like alsamixer, or GUI for visual apps like pavucontrol.'" \
                --field='!gtk-help!Terminal Emulator':BTN "yad --info --title='Info' --borders=15 --text='Type your terminal emulator command (Required for CLI Mixers).'")

            [ -z "$new_configs" ] && break

            IFS='|' read -r ch_name v_step m_app m_type t_emu _ <<EOF
$new_configs
EOF

            if [ -n "$m_app" ] && ! exists "$m_app"; then
                yad --title="Invalid Mixer" --text="The application '$m_app' was not found in your system PATH." --image="dialog-error" --borders=15 --button="Try Again:0"
                continue
            fi

            if [ "$m_type" = "CLI" ]; then
                if [ -n "$t_emu" ] && ! exists "$t_emu"; then
                    yad --title="Invalid Terminal" --text="You selected CLI mixer, but '$t_emu' was not found." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                elif [ -z "$t_emu" ]; then
                    yad --title="Missing Terminal" --text="You must specify a terminal emulator for CLI mixers." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                fi
            else
                t_emu=""
            fi

            [ ! -f "$config_file" ] && touch "$config_file"

            sed -i '/^mixer_channel=/d; /^vol_step=/d; /^mixer_app=/d; /^mixer_type=/d; /^terminal=/d; /^term_emu=/d' "$config_file"
            
            {
              echo "mixer_channel='$ch_name'"
              echo "vol_step=$v_step"
              echo "mixer_app='$m_app'"
              echo "mixer_type='$m_type'"
              echo "terminal='$t_emu'"
            } >> "$config_file"
            
            grep -q "^waybar_signal=" "$config_file" || echo "waybar_signal='$waybar_signal'" >> "$config_file"
            grep -q "^sfwbar_signal=" "$config_file" || echo "sfwbar_signal='$sfwbar_signal'" >> "$config_file"

            break
        done
        ;;

    select_card)
        current_default=""
        if [ -f "$HOME/.asoundrc" ]; then
            current_default=$(awk '/^!defaults.pcm.card/ {print $2}' "$HOME/.asoundrc" | head -n 1 | tr -d '"'\''')
        fi

        cards=$(awk -v cur="$current_default" '
            BEGIN { default_str = ""; other_str = "" }
            /^[ \t]*[0-9]+ \[/ {
                s = index($0, "["); e = index($0, "]");
                id = substr($0, s + 1, e - s - 1);
                gsub(/^[ \t]+|[ \t]+$/, "", id);

                idx = index($0, "]: ");
                driver_raw = substr($0, idx + 3);
                split(driver_raw, d_arr, " - ");
                driver = d_arr[1];
                gsub(/^[ \t]+|[ \t]+$/, "", driver);

                getline; desc = $0;
                gsub(/^[ \t]+|[ \t]+$/, "", desc);
                sub(/ at .*/, "", desc);
                gsub(/[\^|\[\]]/, "", desc);

                if (seen[id] == 1) next;
                seen[id] = 1;

                item = driver " - " desc " [" id "]";

                if (id == cur) {
                    default_str = item;
                } else {
                    if (other_str == "") other_str = item;
                    else other_str = other_str "\n" item;
                }
            }
            END {
                if (default_str != "") print default_str;
                if (other_str != "") print other_str;
            }
        ' /proc/asound/cards)

        if [ -z "$cards" ]; then die -g "No ALSA sound cards detected."; fi

        combo_string=$(printf '%s\n' "$cards" | tr '\n' '^' | sed 's/\^$//')

        selection=$(yad --title="Default Sound Card" \
            --window-icon="audio-card" \
            --image="audio-card" \
            --image-on-top \
            --text="Select the default ALSA audio device for your system:\n" \
            --borders=15 \
            --form \
            --separator="|" \
            --item-separator="^" \
            --field="Default Card:CB" "$combo_string" \
            --button="Save:0" --button="Cancel:1")

        [ -z "$selection" ] && exit 0

        chosen_id=$(printf '%s\n' "$selection" | sed 's/.*\[\([^]]*\)\].*/\1/')
        [ -z "$chosen_id" ] && exit 0
        [ "$chosen_id" = "$current_default" ] && exit 0

        cat <<EOF > "$HOME/.asoundrc"
# Auto-generated by PMT2e Soundcard Selector
!defaults.pcm.card $chosen_id
!defaults.ctl.card $chosen_id
EOF

        if exists dunstify; then
            dunstify -t 2000 -h string:x-dunst-stack-tag:volume -i audio-card "Sound Card Updated" "Default set to: $chosen_id"
        fi
        ;;

    open_mixer)
        if [ "$mixer_type" = "GUI" ]; then
            if exists "$mixer_app"; then
                $mixer_app &
            else
                $0 -c
            fi
            exit 0
        fi

        if [ -z "$terminal" ] || ! exists "$terminal"; then
            yad --title="Missing Terminal" \
                --text="No valid terminal emulator found or configured.\nPlease set one to open your CLI mixer." \
                --window-icon="dialog-warning" \
                --borders=15 \
                --button="Settings:0" --button="Cancel:1"
            [ $? -eq 0 ] && $0 -c
            exit 0
        fi

        $terminal -e $mixer_app &
        ;;

    menu)
        printf "Select Sound Card,%s -S\nOpen Mixer,%s -M\nConfiguration,%s -c\n" \
            "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;

    set_vol)
        amixer sset "$mixer_channel" "${input_vol}%" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_up)
        if [ "$state" = "off" ]; then amixer sset "$mixer_channel" toggle >/dev/null 2>&1; fi
        amixer sset "$mixer_channel" "${vol_step}%+" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_down)
        if [ "$state" = "off" ]; then amixer sset "$mixer_channel" toggle >/dev/null 2>&1; fi
        amixer sset "$mixer_channel" "${vol_step}%-" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    mute_toggle)
        amixer sset "$mixer_channel" toggle >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    text)
        if [ "$state" = "off" ]; then echo "Muted"
        else echo "${vol}%"
        fi
        ;;

    glyph)
        if [ "$state" = "off" ]; then echo "󰝟"
        elif [ "$vol" -ge 90 ]; then echo "󰕾"
        elif [ "$vol" -ge 33 ]; then echo "󰖀"
        else echo "󰕿"
        fi
        ;;

    icon)
        if [ "$state" = "off" ] || [ "$vol" -eq 0 ]; then echo "audio-volume-muted-symbolic"
        elif [ "$vol" -ge 70 ]; then echo "audio-volume-high-symbolic"
        elif [ "$vol" -ge 30 ]; then echo "audio-volume-medium-symbolic"
        else echo "audio-volume-low-symbolic"
        fi
        ;;
esac#!/bin/sh
# ==============================================================================
# Script Name  : pmvolume
# Description  : PMT2e Volume Executor - A lightweight ALSA volume monitor
# Author       : purpleleaf
# Credits      : Piotr Miller (nwg-piotr) - Original creator of the t2ec project
# License      : GPL-3.0
# Dependencies : alsa-utils (amixer), yad, jgmenu, dunstify (optional)
# ==============================================================================

# --- Default Configuration ---
mixer_channel="Auto"
vol_step=5
mixer_app="alsamixer"
mixer_type="CLI"
term_emu=""
waybar_signal="9"
sfwbar_signal="5"

# --- Load User Configuration Safely ---
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmvolume.conf"

if [ -f "$config_file" ] && [ -r "$config_file" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        case "$key" in
            mixer_channel) mixer_channel="$val" ;;
            vol_step)      vol_step="$val" ;;
            mixer_app)     mixer_app="$val" ;;
            mixer_type)    mixer_type="$val" ;;
            term_emu)      term_emu="$val" ;;
            waybar_signal) waybar_signal="$val" ;;
            sfwbar_signal) sfwbar_signal="$val" ;;
        esac
    done < "$config_file"
fi

# --- Global Variables ---
scriptname=$(basename "$0")
action="text" # Default action if no arguments are passed
input_vol=""

# --- Utility Functions ---

exists() {
    command -v "$1" >/dev/null 2>&1
}

show_dialog() {
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
}

die() {
    if [ "$1" = "-g" ]; then
        shift
        if exists yad; then
            show_dialog "$*" "Error" "dialog-error"
        else
            printf '%s\n' "$*" 1>&2
        fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

show_help() {
    cat << EOF
Usage: $scriptname [OPTION]

PMT2e Volume Executor - A lightweight ALSA volume monitor for panels.
Defaults to '-t' (text output) if no options are provided.

Options:
  -t      Print volume text (e.g., 50% or Muted)
  -i      Print the path to the current volume icon (SVG)
  -f      Print the volume Nerd Font glyph
  -u      Increase volume by the configured step
  -d      Decrease volume by the configured step
  -x      Toggle mute state
  -s NUM  Set volume to specific number (0-100)
  -m      Generate jgmenu formatted output for context menus
  -M      Open the configured audio mixer
  -S      Open the default sound card selector
  -c      Open the configuration GUI
  -h      Show this help message and exit
EOF
}

# --- ALSA Parsing (BusyBox/BSD Compatible) ---

get_channel() {
    if [ "$mixer_channel" = "Auto" ] || [ -z "$mixer_channel" ]; then
        mixer_channel=$(
            amixer scontrols |
            while IFS= read -r ctl; do
                case "$ctl" in
                    *"'"*"'"*)
                        name=$(printf '%s\n' "$ctl" | sed "s/.*'\(.*\)'.*/\1/")
                        if amixer get "$name" | grep -q '%'; then
                            printf '%s\n' "$name"
                            break
                        fi
                        ;;
                esac
            done
        )
    fi
    [ -n "$mixer_channel" ] || die -g "No volume control available on this device."
}

get_volume() {
    vol_out=$(
        amixer get "$mixer_channel" |
        while IFS= read -r line; do
            case "$line" in
                *%*)
                    set -- $(printf '%s\n' "$line" | tr '[]' ' ')
                    for field in "$@"; do
                        case "$field" in
                            *%)
                                printf '%s\n' "${field%\%}"
                                return 0
                                ;;
                        esac
                    done
                    ;;
            esac
        done
    )

    case "$vol_out" in
        ''|*[!0-9]*) die -g "Failed to read numeric volume from control: $mixer_channel" ;;
        *) vol="$vol_out" ;;
    esac

    if amixer get "$mixer_channel" | grep '%' | grep -q off; then
        state="off"
    else
        state="on"
    fi
}

# --- Notification Logic ---

send_notification() {
    if exists dunstify; then
        if [ "$state" = "off" ]; then
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i audio-volume-muted-symbolic -u normal "Volume Muted"
        else
            if [ "$vol" -ge 70 ]; then
                icon="audio-volume-high-symbolic"
            elif [ "$vol" -ge 30 ]; then
                icon="audio-volume-medium-symbolic"
            else
                icon="audio-volume-low-symbolic"
            fi
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i "$icon" -h int:value:"$vol" -u normal "Volume: ${vol}%"
        fi
    fi
}

broadcast_refresh() {
    # Check if Waybar is running before signaling
    if pgrep -x "waybar" >/dev/null; then
        pkill -RTMIN+"$waybar_signal" waybar
    fi

    # Check if sfwbar is running before signaling
    if pgrep -x "sfwbar" >/dev/null; then
        pkill -RTMIN+"$sfwbar_signal" sfwbar
    fi
}

# --- Main Logic / Argument Parsing ---

if [ $# -gt 0 ]; then
    action=""
    while getopts ":StfhiudxmMcs:" opt; do
        case ${opt} in
            S) action=select_card ;;
            t) action=text ;;
            f) action=glyph ;;
            i) action=icon ;;
            u) action=vol_up ;;
            d) action=vol_down ;;
            x) action=mute_toggle ;;
            m) action=menu ;;
            M) action=open_mixer ;;
            c) action=config ;;
            s)
                action=set_vol
                case "$OPTARG" in
                    ''|*[!0-9]*) die "Error: -s argument must be a number 0-100" ;;
                    *) [ "$OPTARG" -ge 0 ] && [ "$OPTARG" -le 100 ] && input_vol="$OPTARG" || die "Error: -s must be 0-100" ;;
                esac
                ;;
            h) show_help; exit 0 ;;
            :)
                printf "%s: option -%s requires an argument (0-100).\n" "$scriptname" "$OPTARG" >&2
                exit 1
                ;;
            \?|*)
                printf "%s: unrecognised option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
                exit 1
                ;;
        esac
    done
fi

if [ -z "$action" ]; then
    printf "%s: missing valid option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
    exit 1
fi

exists amixer || die -g "amixer not found; ALSA tools required."

# Bypass ALSA volume querying if we are just opening a GUI
case $action in
    config|help|select_card) ;;
    *) get_channel; get_volume ;;
esac

# --- Action Execution ---

case ${action} in
    config)
        mkdir -p "$config_dir"

        while true; do
            # Build ALSA dropdown
            combo_list="$mixer_channel"
            [ "$mixer_channel" != "Auto" ] && combo_list="${combo_list}!Auto"

            extra_controls=$(amixer scontrols 2>/dev/null | sed -n "s/.*'\(.*\)'.*/\1/p" | while read -r c; do
                [ "$c" != "$mixer_channel" ] && printf "!%s" "$c"
            done)
            combo_list="${combo_list}${extra_controls}"

            # Set Type dropdown order dynamically
            if [ "$mixer_type" = "GUI" ]; then
                type_combo="GUI!CLI"
            else
                type_combo="CLI!GUI"
            fi

            new_configs=$(yad --title="PM Volume configuration" \
                --window-icon="multimedia-volume-control" \
                --form \
                --columns=2 \
                --field="ALSA Channel:":CB "$combo_list" \
                --field="Volume Step (%):NUM" "$vol_step"'!1..100!1!0' \
                --field="Mixer App:" "$mixer_app" \
                --field="Mixer Type:":CB "$type_combo" \
                --field="Terminal Emulator:" "$term_emu" \
                --field='!gtk-help!ALSA Channel':BTN "yad --info --title='Info' --borders=15 --text='Select the ALSA control. Auto will attempt to find the default volume slider.'" \
                --field='!gtk-help!Volume Step Size':BTN "yad --info --title='Info' --borders=15 --text='How much the volume changes when using the up/down commands.'" \
                --field='!gtk-help!Mixer App':BTN "yad --info --title='Info' --borders=15 --text='The mixer to launch (e.g., alsamixer, qasmixer).'" \
                --field='!gtk-help!Mixer Type':BTN "yad --info --title='Info' --borders=15 --text='Select CLI for terminal apps like alsamixer, or GUI for visual apps like pavucontrol.'" \
                --field='!gtk-help!Terminal Emulator':BTN "yad --info --title='Info' --borders=15 --text='Required if you selected CLI Mixer above (e.g., alacritty, xterm).'")

            if [ -z "$new_configs" ]; then
                break
            fi

            IFS='|' read -r ch_name v_step m_app m_type t_emu _ <<EOF
$new_configs
EOF

            if [ -n "$m_app" ] && ! exists "$m_app"; then
                yad --title="Invalid Mixer" --text="The application '$m_app' was not found in your system PATH." --image="dialog-error" --borders=15 --button="Try Again:0"
                continue
            fi

            if [ "$m_type" = "CLI" ]; then
                if [ -n "$t_emu" ] && ! exists "$t_emu"; then
                    yad --title="Invalid Terminal" --text="You selected CLI mixer, but '$t_emu' was not found in your PATH." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                elif [ -z "$t_emu" ]; then
                    yad --title="Missing Terminal" --text="You must specify a terminal emulator for CLI mixers." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                fi
            else
                # Clean up terminal field if GUI is selected
                t_emu=""
            fi

            # Safely write/update the config file, preserving user signal overrides
            [ ! -f "$config_file" ] && touch "$config_file"

            # Clean out the old ALSA lines, then append the new ones
            sed -i '/^mixer_channel=/d; /^vol_step=/d; /^mixer_app=/d; /^mixer_type=/d; /^term_emu=/d' "$config_file"

            {
              echo "mixer_channel='$ch_name'"
              echo "vol_step=$v_step"
              echo "mixer_app='$m_app'"
              echo "mixer_type='$m_type'"
              echo "term_emu='$t_emu'"
            } >> "$config_file"

            # If signals are missing, populate them with defaults so the user knows they exist
            grep -q "^waybar_signal=" "$config_file" || echo "waybar_signal='$waybar_signal'" >> "$config_file"
            grep -q "^sfwbar_signal=" "$config_file" || echo "sfwbar_signal='$sfwbar_signal'" >> "$config_file"

            break
        done
        ;;

    select_card)
        current_default=""
        if [ -f "$HOME/.asoundrc" ]; then
            current_default=$(awk '/^!defaults.pcm.card/ {print $2}' "$HOME/.asoundrc" | head -n 1 | tr -d '"'\''')
        fi

        cards=$(awk -v cur="$current_default" '
            BEGIN { default_str = ""; other_str = "" }
            /^[ \t]*[0-9]+ \[/ {
                s = index($0, "["); e = index($0, "]");
                id = substr($0, s + 1, e - s - 1);
                gsub(/^[ \t]+|[ \t]+$/, "", id);

                idx = index($0, "]: ");
                driver_raw = substr($0, idx + 3);
                split(driver_raw, d_arr, " - ");
                driver = d_arr[1];
                gsub(/^[ \t]+|[ \t]+$/, "", driver);

                getline; desc = $0;
                gsub(/^[ \t]+|[ \t]+$/, "", desc);
                sub(/ at .*/, "", desc);
                gsub(/[\^|\[\]]/, "", desc);

                if (seen[id] == 1) next;
                seen[id] = 1;

                item = driver " - " desc " [" id "]";

                if (id == cur) {
                    default_str = item;
                } else {
                    if (other_str == "") other_str = item;
                    else other_str = other_str "\n" item;
                }
            }
            END {
                if (default_str != "") print default_str;
                if (other_str != "") print other_str;
            }
        ' /proc/asound/cards)

        if [ -z "$cards" ]; then
            die -g "No ALSA sound cards detected."
        fi

        combo_string=$(printf '%s\n' "$cards" | tr '\n' '^' | sed 's/\^$//')

        selection=$(yad --title="Default Sound Card" \
            --window-icon="audio-card" \
            --image="audio-card" \
            --image-on-top \
            --text="Select the default ALSA audio device for your system:\n" \
            --borders=15 \
            --form \
            --separator="|" \
            --item-separator="^" \
            --field="Default Card:CB" "$combo_string" \
            --button="Save:0" --button="Cancel:1")

        [ -z "$selection" ] && exit 0

        chosen_id=$(printf '%s\n' "$selection" | sed 's/.*\[\([^]]*\)\].*/\1/')
        [ -z "$chosen_id" ] && exit 0
        [ "$chosen_id" = "$current_default" ] && exit 0

        cat <<EOF > "$HOME/.asoundrc"
# Auto-generated by PMT2e Soundcard Selector
!defaults.pcm.card $chosen_id
!defaults.ctl.card $chosen_id
EOF

        if exists dunstify; then
            dunstify -t 2000 -h string:x-dunst-stack-tag:volume -i audio-card "Sound Card Updated" "Default set to: $chosen_id"
        fi
        ;;

    open_mixer)
        if [ "$mixer_type" = "GUI" ]; then
            if exists "$mixer_app"; then
                $mixer_app &
            else
                $0 -c
            fi
            exit 0
        fi

        if [ -z "$term_emu" ] || ! exists "$term_emu"; then
            yad --title="Missing Terminal" \
                --text="No valid terminal emulator configured.\nPlease set one to open your CLI mixer." \
                --window-icon="dialog-warning" \
                --image="dialog-warning" \
                --borders=15 \
                --button="Settings:0" --button="Cancel:1"

            if [ $? -eq 0 ]; then
                $0 -c
            fi
            exit 0
        fi

        $term_emu -e $mixer_app &
        ;;

    menu)
        printf "Select Sound Card,%s -S\nOpen Mixer,%s -M\nConfiguration,%s -c\n" \
            "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;

    set_vol)
        amixer sset "$mixer_channel" "${input_vol}%" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_up)
        if [ "$state" = "off" ]; then amixer sset "$mixer_channel" toggle >/dev/null 2>&1; fi
        amixer sset "$mixer_channel" "${vol_step}%+" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_down)
        if [ "$state" = "off" ]; then amixer sset "$mixer_channel" toggle >/dev/null 2>&1; fi
        amixer sset "$mixer_channel" "${vol_step}%-" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    mute_toggle)
        amixer sset "$mixer_channel" toggle >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    text)
        if [ "$state" = "off" ]; then
            echo "Muted"
        else
            echo "${vol}%"
        fi
        ;;

    glyph)
        if [ "$state" = "off" ]; then
            echo "󰝟"
        elif [ "$vol" -ge 90 ]; then echo "󰕾"
        elif [ "$vol" -ge 33 ]; then echo "󰖀"
        else echo "󰕿"
        fi
        ;;

    icon)
        if [ "$state" = "off" ] || [ "$vol" -eq 0 ]; then
            echo "audio-volume-muted-symbolic"
        elif [ "$vol" -ge 70 ]; then echo "audio-volume-high-symbolic"
        elif [ "$vol" -ge 30 ]; then echo "audio-volume-medium-symbolic"
        else echo "audio-volume-low-symbolic"
        fi
        ;;

    *)
        printf "%s: unrecognised option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
        exit 1
        ;;
esac
