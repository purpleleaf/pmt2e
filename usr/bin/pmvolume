#!/bin/sh
# ==============================================================================
# Script Name  : pmvolume
# Description  : PMT2e Volume Executor - Strict Verticality Gold Standard
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : alsa-utils, yad, jgmenu, dunstify
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmvolume.conf"
gui_lock="/tmp/${scriptname}_gui.lock"

# ---------------------------------------------------------
# Utilities & Requirements Check
# ---------------------------------------------------------
exists() {
    command -v "$1" >/dev/null 2>&1
}

show_help() {
    printf "Usage: %s [OPTION]\n\n" "$scriptname"
    printf "PMT2e Volume Executor - A lightweight ALSA volume monitor for panels.\n"
    printf "Defaults to '-t' (text output) if no options are provided.\n\n"
    printf "ACTIONS (Choose exactly one):\n"
    printf "  -u        Increase volume by the configured step\n"
    printf "  -d        Decrease volume by the configured step\n"
    printf "  -x        Toggle mute state\n"
    printf "  -s NUM    Set volume to specific number (0-100)\n"
    printf "  -M        Open the configured audio mixer\n"
    printf "  -S        Open the default sound card selector\n"
    printf "  -c        Open the configuration GUI\n"
    printf "  -m        Show interactive jgmenu\n"
    printf "  -h        Show this help message and exit\n\n"
    printf "OUTPUT FORMATS (Optional):\n"
    printf "  -t        Print volume text (e.g., 50%% or Muted) [DEFAULT]\n"
    printf "  -f        Print the volume Nerd Font glyph\n"
    printf "  -i        Print the path to the current volume icon (SVG)\n"
    exit 0
}

show_dialog() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi

    touch "$gui_lock"

    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0" \
        --center

    rm -f "$gui_lock"
}

die() {
    msg="$1"
    if [ "$2" = "-g" ]; then
        if exists yad; then
            show_dialog "$msg" "Volume Error" "dialog-error"
        else
            printf '%s\n' "$msg" 1>&2
        fi
    else
        printf '%s\n' "$msg" 1>&2
    fi
    exit 1
}

for req in amixer yad jgmenu; do
    if ! exists "$req"; then
        die "Error: dependency '$req' is not installed."
    fi
done

# ---------------------------------------------------------
# Configuration & Environment
# ---------------------------------------------------------
terminal_list="xterm $TERMINAL x-terminal-emulator alacritty kitty foot ghostty urxvt rxvt st qterminal gnome-terminal xfce4-terminal mate-terminal terminology"
terminal=""

for term in $terminal_list; do
    if [ -n "$term" ]; then
        if exists "$term"; then
            terminal="$term"
            break
        fi
    fi
done

mixer_channel="Auto"
vol_step=5
mixer_app="alsamixer"
mixer_type="CLI"
waybar_signal="9"
sfwbar_signal="5"

if [ -f "$config_file" ] && [ -r "$config_file" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
        val="${val%\"}"
        val="${val#\"}"
        val="${val%\'}"
        val="${val#\'}"
        case "$key" in
            mixer_channel)
                mixer_channel="$val"
                ;;
            vol_step)
                vol_step="$val"
                ;;
            mixer_app)
                mixer_app="$val"
                ;;
            mixer_type)
                mixer_type="$val"
                ;;
            terminal|term_emu)
                terminal="$val"
                ;;
            waybar_signal)
                waybar_signal="$val"
                ;;
            sfwbar_signal)
                sfwbar_signal="$val"
                ;;
        esac
    done < "$config_file"
fi

# ---------------------------------------------------------
# ALSA Logic (Backend)
# ---------------------------------------------------------
get_channel() {
    if [ "$mixer_channel" = "Auto" ] || [ -z "$mixer_channel" ]; then
        mixer_channel=$(
            amixer scontrols | while IFS= read -r ctl; do
                case "$ctl" in
                    *"'"*"'"*)
                        name=$(printf '%s\n' "$ctl" | sed "s/.*'\(.*\)'.*/\1/")
                        if amixer get "$name" | grep -q '%'; then
                            printf '%s\n' "$name"
                            break
                        fi
                        ;;
                esac
            done
        )
    fi

    if [ -z "$mixer_channel" ]; then
        die "No volume control available on this device." -g
    fi
}

get_volume() {
    vol_out=$(
        amixer get "$mixer_channel" | while IFS= read -r line; do
            case "$line" in
                *%*)
                    set -- $(printf '%s\n' "$line" | tr '[]' ' ')
                    for field in "$@"; do
                        case "$field" in
                            *%)
                                printf '%s\n' "${field%\%}"
                                return 0
                                ;;
                        esac
                    done
                    ;;
            esac
        done
    )

    case "$vol_out" in
        ''|*[!0-9]*)
            die "Failed to read numeric volume from control: $mixer_channel" -g
            ;;
        *)
            vol="$vol_out"
            ;;
    esac

    if amixer get "$mixer_channel" | grep '%' | grep -q off; then
        state="off"
    else
        state="on"
    fi
}

# ---------------------------------------------------------
# UI & Output Handlers (Frontend)
# ---------------------------------------------------------
send_notification() {
    if exists dunstify; then
        if [ "$state" = "off" ]; then
            dunstify -t 1000 \
                -h string:x-dunst-stack-tag:volume \
                -i audio-volume-muted-symbolic \
                -u normal "Volume Muted"
        else
            if [ "$vol" -ge 70 ]; then
                icon="audio-volume-high-symbolic"
            elif [ "$vol" -ge 30 ]; then
                icon="audio-volume-medium-symbolic"
            else
                icon="audio-volume-low-symbolic"
            fi

            dunstify -t 1000 \
                -h string:x-dunst-stack-tag:volume \
                -i "$icon" \
                -h int:value:"$vol" \
                -u normal "Volume: ${vol}%"
        fi
    fi
}

broadcast_refresh() {
    if pgrep -x "waybar" >/dev/null; then
        pkill -RTMIN+"$waybar_signal" waybar
    fi
    if pgrep -x "sfwbar" >/dev/null; then
        pkill -RTMIN+"$sfwbar_signal" sfwbar
    fi
}

do_open_mixer() {
    if [ "$mixer_type" = "GUI" ]; then
        if exists "$mixer_app"; then
            $mixer_app &
        else
            "$0" -c
        fi
        exit 0
    fi

    term_valid=0
    if [ -n "$terminal" ]; then
        if exists "$terminal"; then
            term_valid=1
        fi
    fi

    if [ "$term_valid" -eq 0 ]; then
        yad --title="Missing Terminal" \
            --text="No valid terminal emulator found or configured.\nPlease set one to open your CLI mixer." \
            --window-icon="dialog-warning" \
            --borders=15 \
            --button="Settings:0" --button="Cancel:1"
        if [ $? -eq 0 ]; then
            "$0" -c
        fi
        exit 0
    fi

    $terminal -e "$mixer_app" &
}

do_config() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi
    touch "$gui_lock"

    while true; do
        combo_list="$mixer_channel"
        if [ "$mixer_channel" != "Auto" ]; then
            combo_list="${combo_list}!Auto"
        fi

        extra_controls=$(amixer scontrols 2>/dev/null | sed -n "s/.*'\(.*\)'.*/\1/p" | while read -r c; do
            if [ "$c" != "$mixer_channel" ]; then
                printf "!%s" "$c"
            fi
        done)

        combo_list="${combo_list}${extra_controls}"

        if [ "$mixer_type" = "GUI" ]; then
            type_combo="GUI!CLI"
        else
            type_combo="CLI!GUI"
        fi

        new_configs=$(yad --title="PM Volume Settings" \
            --window-icon="multimedia-volume-control" \
            --form --columns=2 --borders=15 \
            --field="ALSA Channel:":CB "$combo_list" \
            --field="Volume Step (%):NUM" "$vol_step"'!1..100!1!0' \
            --field="Mixer App:" "$mixer_app" \
            --field="Mixer Type:":CB "$type_combo" \
            --field="Terminal Emulator:" "$terminal" \
            --field='!gtk-help!ALSA Channel':BTN "yad --info --text='Select the ALSA control.' --borders=15" \
            --field='!gtk-help!Step Size':BTN "yad --info --text='Volume change amount.' --borders=15" \
            --field='!gtk-help!Mixer App':BTN "yad --info --text='Command to launch.' --borders=15" \
            --field='!gtk-help!Mixer Type':BTN "yad --info --text='CLI or GUI.' --borders=15" \
            --field='!gtk-help!Terminal':BTN "yad --info --text='Terminal emulator.' --borders=15" \
            --button="Save:0" --button="Cancel:1")

        if [ -z "$new_configs" ]; then
            break
        fi

        ch_name=$(printf '%s\n' "$new_configs" | cut -d'|' -f1)
        v_step=$(printf '%s\n' "$new_configs" | cut -d'|' -f2)
        m_app=$(printf '%s\n' "$new_configs" | cut -d'|' -f3)
        m_type=$(printf '%s\n' "$new_configs" | cut -d'|' -f4)
        t_emu=$(printf '%s\n' "$new_configs" | cut -d'|' -f5)

        if [ -n "$m_app" ]; then
            if ! exists "$m_app"; then
                yad --title="Error" --text="Mixer not found." --image="dialog-error" --borders=15
                continue
            fi
        fi

        mkdir -p "$config_dir"
        sed -i '/^mixer_channel=/d; /^vol_step=/d; /^mixer_app=/d; /^mixer_type=/d; /^terminal=/d' "$config_file"
        {
          echo "mixer_channel='$ch_name'"
          echo "vol_step=$v_step"
          echo "mixer_app='$m_app'"
          echo "mixer_type='$m_type'"
          echo "terminal='$t_emu'"
        } >> "$config_file"
        break
    done
    rm -f "$gui_lock"
}

do_select_card() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi
    touch "$gui_lock"

    cards=$(awk '
        /^[ \t]*[0-9]+ \[/ {
            s = index($0, "["); e = index($0, "]");
            id = substr($0, s + 1, e - s - 1);
            gsub(/^[ \t]+|[ \t]+$/, "", id);
            idx = index($0, "]: ");
            driver = substr($0, idx + 3);
            split(driver, d_arr, " - ");
            item = d_arr[1] " [" id "]";
            print item;
        }
    ' /proc/asound/cards)

    if [ -z "$cards" ]; then
        die "No ALSA sound cards detected." -g
    fi

    combo_string=$(printf '%s\n' "$cards" | tr '\n' '^' | sed 's/\^$//')
    selection=$(yad --title="Sound Card Selector" \
        --form --borders=15 \
        --field="Default Card:CB" "$combo_string" \
        --button="Apply:0" --button="Cancel:1")

    if [ -n "$selection" ]; then
        chosen_id=$(printf '%s\n' "$selection" | sed 's/.*\[\([^]]*\)\].*/\1/')
        cat <<EOF > "$HOME/.asoundrc"
# PMT2e Auto-generated
!defaults.pcm.card $chosen_id
!defaults.ctl.card $chosen_id
EOF
        if exists dunstify; then
            dunstify -i audio-card "Sound Card Updated" "Default set to: $chosen_id"
        fi
    fi
    rm -f "$gui_lock"
}

# ---------------------------------------------------------
# Main Execution Logic
# ---------------------------------------------------------
action=""
output="text"
input_vol=""

err_act="Only one action can be chosen."
err_out="Only one output can be chosen."

while getopts ":StfhiudxmMcs:" opt; do
    case ${opt} in
        h)
            show_help
            ;;
        S)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="select_card"
            ;;
        t)
            output="text"
            ;;
        f)
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="glyph"
            ;;
        i)
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="icon"
            ;;
        u)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="vol_up"
            ;;
        d)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="vol_down"
            ;;
        x)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="mute_toggle"
            ;;
        M)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="open_mixer"
            ;;
        c)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="config"
            ;;
        m)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="menu"
            ;;
        s)
            if [ -n "$action" ]; then die "$err_act"; fi
            action="set_vol"
            input_vol="$OPTARG"
            ;;
        \?|*)
            die "Invalid option. Use -h for help."
            ;;
    esac
done

if [ -z "$action" ]; then
    action="poll"
fi

case $action in
    config|select_card|menu|open_mixer)
        ;;
    *)
        get_channel
        get_volume
        ;;
esac

case "$action" in
    config)
        do_config
        ;;
    select_card)
        do_select_card
        ;;
    menu)
        printf "Card Selector,%s -S\nMixer,%s -M\nConfig,%s -c\n" "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;
    open_mixer)
        do_open_mixer
        ;;
    vol_up)
        if [ "$state" = "off" ]; then
            amixer sset "$mixer_channel" toggle >/dev/null
        fi
        amixer sset "$mixer_channel" "${vol_step}%+" >/dev/null
        get_volume
        send_notification
        broadcast_refresh
        ;;
    vol_down)
        if [ "$state" = "off" ]; then
            amixer sset "$mixer_channel" toggle >/dev/null
        fi
        amixer sset "$mixer_channel" "${vol_step}%-" >/dev/null
        get_volume
        send_notification
        broadcast_refresh
        ;;
    mute_toggle)
        amixer sset "$mixer_channel" toggle >/dev/null
        get_volume
        send_notification
        broadcast_refresh
        ;;
    set_vol)
        amixer sset "$mixer_channel" "${input_vol}%" >/dev/null
        get_volume
        send_notification
        broadcast_refresh
        ;;
    poll)
        case "$output" in
            text)
                if [ "$state" = "off" ]; then
                    echo "Muted"
                else
                    echo "${vol}%"
                fi
                ;;
            glyph)
                if [ "$state" = "off" ]; then
                    echo "󰝟"
                elif [ "$vol" -ge 90 ]; then
                    echo "󰕾"
                elif [ "$vol" -ge 33 ]; then
                    echo "󰖀"
                else
                    echo "󰕿"
                fi
                ;;
            icon)
                if [ "$state" = "off" ]; then
                    echo "audio-volume-muted-symbolic"
                elif [ "$vol" -ge 70 ]; then
                    echo "audio-volume-high-symbolic"
                elif [ "$vol" -ge 30 ]; then
                    echo "audio-volume-medium-symbolic"
                else
                    echo "audio-volume-low-symbolic"
                fi
                ;;
        esac
        ;;
esac
