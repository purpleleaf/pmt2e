#!/bin/sh
# ==============================================================================
# Script Name  : pmvolume
# Description  : PMT2e Volume Executor - A lightweight ALSA volume monitor
# Author       : purpleleaf
# Credits      : Piotr Miller (nwg-piotr) - Original creator of the t2ec project
# License      : GPL-3.0
# Dependencies : alsa-utils (amixer), yad, jgmenu, dunstify (optional)
# ==============================================================================

# --- Default Configuration ---
MIXER_CHANNEL="Auto"
VOL_STEP=5
MIXER_APP="alsamixer"
MIXER_TYPE="CLI"
TERM_EMU=""

# --- Load User Configuration Safely ---
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
CONFIG_FILE="$CONFIG_DIR/pmvolume.conf"

if [ -f "$CONFIG_FILE" ] && [ -r "$CONFIG_FILE" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        case "$key" in
            MIXER_CHANNEL) MIXER_CHANNEL="$val" ;;
            VOL_STEP)      VOL_STEP="$val" ;;
            MIXER_APP)     MIXER_APP="$val" ;;
            MIXER_TYPE)    MIXER_TYPE="$val" ;;
            TERM_EMU)      TERM_EMU="$val" ;;
        esac
    done < "$CONFIG_FILE"
fi

# --- Global Variables ---
scriptname=$(basename "$0")
action="text" # Default action if no arguments are passed
input_vol=""

# --- Utility Functions ---

exists() {
    command -v "$1" >/dev/null 2>&1
}

show_dialog() {
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
}

die() {
    if [ "$1" = "-g" ]; then
        shift
        if exists yad; then
            show_dialog "$*" "Error" "dialog-error"
        else
            printf '%s\n' "$*" 1>&2
        fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

show_help() {
    cat << EOF
Usage: $scriptname [OPTION]

PMT2e Volume Executor - A lightweight ALSA volume monitor for panels.
Defaults to '-t' (text output) if no options are provided.

Options:
  -t      Print volume text (e.g., 50% or Muted)
  -i      Print the path to the current volume icon (SVG)
  -f      Print the volume Nerd Font glyph
  -u      Increase volume by the configured step
  -d      Decrease volume by the configured step
  -x      Toggle mute state
  -s NUM  Set volume to specific number (0-100)
  -m      Generate jgmenu formatted output for context menus
  -M      Open the configured audio mixer
  -S      Open the default sound card selector
  -c      Open the configuration GUI
  -h      Show this help message and exit
EOF
}

# --- ALSA Parsing (BusyBox/BSD Compatible) ---

get_channel() {
    if [ "$MIXER_CHANNEL" = "Auto" ] || [ -z "$MIXER_CHANNEL" ]; then
        MIXER_CHANNEL=$(
            amixer scontrols |
            while IFS= read -r ctl; do
                case "$ctl" in
                    *"'"*"'"*)
                        name=$(printf '%s\n' "$ctl" | sed "s/.*'\(.*\)'.*/\1/")
                        if amixer get "$name" | grep -q '%'; then
                            printf '%s\n' "$name"
                            break
                        fi
                        ;;
                esac
            done
        )
    fi
    [ -n "$MIXER_CHANNEL" ] || die -g "No volume control available on this device."
}

get_volume() {
    vol_out=$(
        amixer get "$MIXER_CHANNEL" |
        while IFS= read -r line; do
            case "$line" in
                *%*)
                    set -- $(printf '%s\n' "$line" | tr '[]' ' ')
                    for field in "$@"; do
                        case "$field" in
                            *%)
                                printf '%s\n' "${field%%%}"
                                return 0
                                ;;
                        esac
                    done
                    ;;
            esac
        done
    )

    case "$vol_out" in
        ''|*[!0-9]*) die -g "Failed to read numeric volume from control: $MIXER_CHANNEL" ;;
        *) vol="$vol_out" ;;
    esac

    if amixer get "$MIXER_CHANNEL" | grep '%' | grep -q off; then
        state="off"
    else
        state="on"
    fi
}

# --- Notification Logic ---

send_notification() {
    if exists dunstify; then
        if [ "$state" = "off" ]; then
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i audio-volume-muted-symbolic -u normal "Volume Muted"
        else
            if [ "$vol" -ge 70 ]; then
                icon="audio-volume-high-symbolic"
            elif [ "$vol" -ge 30 ]; then
                icon="audio-volume-medium-symbolic"
            else
                icon="audio-volume-low-symbolic"
            fi
            dunstify -t 1000 -h string:x-dunst-stack-tag:volume -i "$icon" -h int:value:"$vol" -u normal "Volume: ${vol}%"
        fi
    fi
}

broadcast_refresh() {
    # Check if Waybar is running before signaling
    if pgrep -x "waybar" >/dev/null; then
        pkill -RTMIN+9 waybar
    fi

    # Check if sfwbar is running before signaling
    if pgrep -x "sfwbar" >/dev/null; then
        pkill -RTMIN+5 sfwbar
    fi
}

# --- Main Logic / Argument Parsing ---

if [ $# -gt 0 ]; then
    action=""
    while getopts ":StfhiudxmMcs:" opt; do
        case ${opt} in
            S) action=select_card ;;
            t) action=text ;;
            f) action=glyph ;;
            i) action=icon ;;
            u) action=vol_up ;;
            d) action=vol_down ;;
            x) action=mute_toggle ;;
            m) action=menu ;;
            M) action=open_mixer ;;
            c) action=config ;;
            s)
                action=set_vol
                case "$OPTARG" in
                    ''|*[!0-9]*) die "Error: -s argument must be a number 0-100" ;;
                    *) [ "$OPTARG" -ge 0 ] && [ "$OPTARG" -le 100 ] && input_vol="$OPTARG" || die "Error: -s must be 0-100" ;;
                esac
                ;;
            h) show_help; exit 0 ;;
            :)
                printf "%s: option -%s requires an argument (0-100).\n" "$scriptname" "$OPTARG" >&2
                exit 1
                ;;
            \?|*)
                printf "%s: unrecognised option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
                exit 1
                ;;
        esac
    done
fi

if [ -z "$action" ]; then
    printf "%s: missing valid option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
    exit 1
fi

exists amixer || die -g "amixer not found; ALSA tools required."

# Bypass ALSA volume querying if we are just opening a GUI
case $action in
    config|help|select_card) ;;
    *) get_channel; get_volume ;;
esac

# --- Action Execution ---

case ${action} in
    config)
        mkdir -p "$CONFIG_DIR"

        while true; do
            # Build ALSA dropdown
            combo_list="$MIXER_CHANNEL"
            [ "$MIXER_CHANNEL" != "Auto" ] && combo_list="${combo_list}!Auto"

            extra_controls=$(amixer scontrols 2>/dev/null | sed -n "s/.*'\(.*\)'.*/\1/p" | while read -r c; do
                [ "$c" != "$MIXER_CHANNEL" ] && printf "!%s" "$c"
            done)
            combo_list="${combo_list}${extra_controls}"

            # Set Type dropdown order dynamically
            if [ "$MIXER_TYPE" = "GUI" ]; then
                type_combo="GUI!CLI"
            else
                type_combo="CLI!GUI"
            fi

            new_configs=$(yad --title="PM Volume configuration" \
                --window-icon="multimedia-volume-control" \
                --form \
                --columns=2 \
                --field="ALSA Channel:":CB "$combo_list" \
                --field="Volume Step (%):NUM" "$VOL_STEP"'!1..100!1!0' \
                --field="Mixer App:" "$MIXER_APP" \
                --field="Mixer Type:":CB "$type_combo" \
                --field="Terminal Emulator:" "$TERM_EMU" \
                --field='!gtk-help!ALSA Channel':BTN "yad --info --title='Info' --borders=15 --text='Select the ALSA control. Auto will attempt to find the default volume slider.'" \
                --field='!gtk-help!Volume Step Size':BTN "yad --info --title='Info' --borders=15 --text='How much the volume changes when using the up/down commands.'" \
                --field='!gtk-help!Mixer App':BTN "yad --info --title='Info' --borders=15 --text='The mixer to launch (e.g., alsamixer, qasmixer).'" \
                --field='!gtk-help!Mixer Type':BTN "yad --info --title='Info' --borders=15 --text='Select CLI for terminal apps like alsamixer, or GUI for visual apps like pavucontrol.'" \
                --field='!gtk-help!Terminal Emulator':BTN "yad --info --title='Info' --borders=15 --text='Required if you selected CLI Mixer above (e.g., alacritty, xterm).'")

            if [ -z "$new_configs" ]; then
                break
            fi

            IFS='|' read -r ch_name v_step m_app m_type t_emu _ <<EOF
$new_configs
EOF

            if [ -n "$m_app" ] && ! exists "$m_app"; then
                yad --title="Invalid Mixer" --text="The application '$m_app' was not found in your system PATH." --image="dialog-error" --borders=15 --button="Try Again:0"
                continue
            fi

            if [ "$m_type" = "CLI" ]; then
                if [ -n "$t_emu" ] && ! exists "$t_emu"; then
                    yad --title="Invalid Terminal" --text="You selected CLI mixer, but '$t_emu' was not found in your PATH." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                elif [ -z "$t_emu" ]; then
                    yad --title="Missing Terminal" --text="You must specify a terminal emulator for CLI mixers." --image="dialog-error" --borders=15 --button="Try Again:0"
                    continue
                fi
            else
                # Clean up terminal field if GUI is selected
                t_emu=""
            fi

            {
              echo "MIXER_CHANNEL='$ch_name'"
              echo "VOL_STEP=$v_step"
              echo "MIXER_APP='$m_app'"
              echo "MIXER_TYPE='$m_type'"
              echo "TERM_EMU='$t_emu'"
            } > "$CONFIG_FILE"
            break
        done
        ;;

    select_card)
        current_default=""
        if [ -f "$HOME/.asoundrc" ]; then
            current_default=$(awk '/^!defaults.pcm.card/ {print $2}' "$HOME/.asoundrc" | head -n 1 | tr -d '"'\''')
        fi

        cards=$(awk -v cur="$current_default" '
            BEGIN { default_str = ""; other_str = "" }
            /^[ \t]*[0-9]+ \[/ {
                s = index($0, "["); e = index($0, "]");
                id = substr($0, s + 1, e - s - 1);
                gsub(/^[ \t]+|[ \t]+$/, "", id);

                idx = index($0, "]: ");
                driver_raw = substr($0, idx + 3);
                split(driver_raw, d_arr, " - ");
                driver = d_arr[1];
                gsub(/^[ \t]+|[ \t]+$/, "", driver);

                getline; desc = $0;
                gsub(/^[ \t]+|[ \t]+$/, "", desc);
                sub(/ at .*/, "", desc);
                gsub(/[\^|\[\]]/, "", desc);

                if (seen[id] == 1) next;
                seen[id] = 1;

                item = driver " - " desc " [" id "]";

                if (id == cur) {
                    default_str = item;
                } else {
                    if (other_str == "") other_str = item;
                    else other_str = other_str "\n" item;
                }
            }
            END {
                if (default_str != "") print default_str;
                if (other_str != "") print other_str;
            }
        ' /proc/asound/cards)

        if [ -z "$cards" ]; then
            die -g "No ALSA sound cards detected."
        fi

        combo_string=$(printf '%s\n' "$cards" | tr '\n' '^' | sed 's/\^$//')

        selection=$(yad --title="Default Sound Card" \
            --window-icon="audio-card" \
            --image="audio-card" \
            --image-on-top \
            --text="Select the default ALSA audio device for your system:\n" \
            --borders=15 \
            --form \
            --separator="|" \
            --item-separator="^" \
            --field="Default Card:CB" "$combo_string" \
            --button="Save:0" --button="Cancel:1")

        [ -z "$selection" ] && exit 0

        chosen_id=$(printf '%s\n' "$selection" | sed 's/.*\[\([^]]*\)\].*/\1/')
        [ -z "$chosen_id" ] && exit 0
        [ "$chosen_id" = "$current_default" ] && exit 0

        cat <<EOF > "$HOME/.asoundrc"
# Auto-generated by PMT2e Soundcard Selector
!defaults.pcm.card $chosen_id
!defaults.ctl.card $chosen_id
EOF

        if exists dunstify; then
            dunstify -t 2000 -h string:x-dunst-stack-tag:volume -i audio-card "Sound Card Updated" "Default set to: $chosen_id"
        fi
        ;;

    open_mixer)
        if [ "$MIXER_TYPE" = "GUI" ]; then
            if exists "$MIXER_APP"; then
                $MIXER_APP &
            else
                $0 -c
            fi
            exit 0
        fi

        if [ -z "$TERM_EMU" ] || ! exists "$TERM_EMU"; then
            yad --title="Missing Terminal" \
                --text="No valid terminal emulator configured.\nPlease set one to open your CLI mixer." \
                --window-icon="dialog-warning" \
                --image="dialog-warning" \
                --borders=15 \
                --button="Settings:0" --button="Cancel:1"

            if [ $? -eq 0 ]; then
                $0 -c
            fi
            exit 0
        fi

        $TERM_EMU -e $MIXER_APP &
        ;;

    menu)
        printf "Select Sound Card,%s -S\nOpen Mixer,%s -M\nConfiguration,%s -c\n" \
            "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;

    set_vol)
        amixer sset "$MIXER_CHANNEL" "${input_vol}%" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_up)
        if [ "$state" = "off" ]; then amixer sset "$MIXER_CHANNEL" toggle >/dev/null 2>&1; fi
        amixer sset "$MIXER_CHANNEL" "${VOL_STEP}%+" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    vol_down)
        if [ "$state" = "off" ]; then amixer sset "$MIXER_CHANNEL" toggle >/dev/null 2>&1; fi
        amixer sset "$MIXER_CHANNEL" "${VOL_STEP}%-" >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    mute_toggle)
        amixer sset "$MIXER_CHANNEL" toggle >/dev/null 2>&1
        get_volume; send_notification; broadcast_refresh
        ;;

    text)
        if [ "$state" = "off" ]; then
            echo "Muted"
        else
            echo "${vol}%"
        fi
        ;;

    glyph)
        if [ "$state" = "off" ]; then
            echo "󰝟"
        elif [ "$vol" -ge 90 ]; then echo "󰕾"
        elif [ "$vol" -ge 33 ]; then echo "󰖀"
        else echo "󰕿"
        fi
        ;;

    icon)
        if [ "$state" = "off" ] || [ "$vol" -eq 0 ]; then
            echo "audio-volume-muted-symbolic"
        elif [ "$vol" -ge 70 ]; then echo "audio-volume-high-symbolic"
        elif [ "$vol" -ge 30 ]; then echo "audio-volume-medium-symbolic"
        else echo "audio-volume-low-symbolic"
        fi
        ;;

    *)
        printf "%s: unrecognised option. Use %s -h for help.\n" "$scriptname" "$scriptname" >&2
        exit 1
        ;;
esac
