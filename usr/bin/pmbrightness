#!/bin/sh
# ==============================================================================
# Script Name  : pmbrightness
# Description  : PMT2e Brightness Agent - Support for light, brightnessctl, xbacklight
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : light OR brightnessctl OR xbacklight, jgmenu, dunstify, yad
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")
lock_file="/tmp/${scriptname}.lock"

# ---------------------------------------------------------
# Error handling & Utilities
# ---------------------------------------------------------
exists() { command -v "$1" >/dev/null 2>&1; }

show_dialog() {
    # If a lock exists, a window is already open. Return silently.
    [ -f "$lock_file" ] && return
    
    # Create the lock
    touch "$lock_file"
    
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
    
    # Remove lock when window is closed
    rm -f "$lock_file"
}

die() {
    if [ "$1" = "-y" ]; then
        shift
        if exists yad; then 
            show_dialog "$*" "Brightness Error" "dialog-error"
        else 
            printf '%s\n' "$*" 1>&2
        fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

show_help() {
    cat << EOF
Usage: $scriptname [Action] | [Output]

PMT2e Brightness Agent - Adjust backlight levels.

ACTIONS (Choose one):
  -u        Increase brightness by 5%
  -d        Decrease brightness by 5%
  -s [0-100] Set brightness to specific percentage
  -g        Launch external GUI slider (pmgui-scale)
  -m        Show interactive jgmenu
  -h        Show this help message and exit

OUTPUT FORMATS:
  -t        Print text output (Default)
  -f        Print Nerd Font glyph
  -i        Print path to brightness SVG icon
EOF
}

# ---------------------------------------------------------
# Backlight Backend Detection & Wrappers
# ---------------------------------------------------------
get_backend() {
    if exists light; then BACKEND="light"
    elif exists brightnessctl; then BACKEND="brightnessctl"
    elif exists xbacklight; then BACKEND="xbacklight"
    else BACKEND=""
    fi
}

get_bri() {
    [ -z "$BACKEND" ] && return 1
    case "$BACKEND" in
        light)         light -G | cut -d'.' -f1 ;;
        brightnessctl) brightnessctl -m | cut -d',' -f4 | tr -d '%' ;;
        xbacklight)    xbacklight -get | cut -d'.' -f1 ;;
    esac
}

set_bri() {
    [ -z "$BACKEND" ] && die -y "No backlight tool found. Please install 'light', 'brightnessctl', or 'xbacklight'."
    val="$1"; mode="$2"
    case "$BACKEND" in
        light)
            case "$mode" in
                set) light -S "$val" ;;
                up)  light -A 5 ;;
                down) light -U 5 ;;
            esac ;;
        brightnessctl)
            case "$mode" in
                set) brightnessctl set "$val%" ;;
                up)  brightnessctl set +5% ;;
                down) brightnessctl set 5%- ;;
            esac ;;
        xbacklight)
            case "$mode" in
                set) xbacklight -set "$val" ;;
                up)  xbacklight -inc 5 ;;
                down) xbacklight -dec 5 ;;
            esac ;;
    esac
}

send_notification() {
    exists dunstify || return
    cur=$(get_bri)
    if [ "$cur" -ge 70 ]; then icon="display-brightness-high-symbolic"
    elif [ "$cur" -ge 30 ]; then icon="display-brightness-medium-symbolic"
    else icon="display-brightness-low-symbolic"; fi
    dunstify -t 1000 -h string:x-dunst-stack-tag:brightness -i "$icon" -h int:value:"$cur" "Brightness: $cur%"
}

# ---------------------------------------------------------
# Execution & Argument Parsing
# ---------------------------------------------------------
get_backend
action=""
output_format=""
input_val=""

[ $# -eq 0 ] && output_format="text"

while getopts ":huds:iftgm" opt; do
    case ${opt} in
        h) show_help; exit 0 ;;
        u) action="up" ;;
        d) action="down" ;;
        s) action="set"; input_val="$OPTARG" ;;
        g) pmgui-scale -b; exit 0 ;;
        m) action="menu" ;;
        i) output_format="icon" ;;
        f) output_format="glyph" ;;
        t) output_format="text" ;;
        \?|*) die "Invalid option. Use -h for help." ;;
    esac
done

if [ -n "$action" ]; then
    case "$action" in
        up)   set_bri "" "up" ;;
        down) set_bri "" "down" ;;
        set)  set_bri "$input_val" "set" ;;
        menu) 
            menu_list=$(
                printf "Brightness GUI,pmgui-scale -b\n"
                printf "^sep()\n"
                printf "Max (100%%),%s -s 100\n" "$scriptname"
                printf "High (75%%),%s -s 75\n" "$scriptname"
                printf "Medium (50%%),%s -s 50\n" "$scriptname"
                printf "Low (25%%),%s -s 25\n" "$scriptname"
                printf "Night (5%%),%s -s 5\n" "$scriptname"
            )
            printf '%s\n' "$menu_list" | createjgmenu
            exit 0
            ;;
    esac
    send_notification
    [ -z "$output_format" ] && exit 0
fi

if [ -n "$output_format" ]; then
    bri=$(get_bri)
    if [ $? -ne 0 ] || [ -z "$BACKEND" ]; then
        case "$output_format" in
            text)  printf 'Bri: N/A\n' ;;
            glyph) printf '󰃠 <span color="red">󱈸</span>\n' ;;
            icon)  printf '%s/bri-error.svg\n' "$iconpath" ;;
        esac
        exit 0
    fi

    case "$output_format" in
        text)  printf 'Bri: %s%%\n' "$bri" ;;
        glyph)
            if [ "$bri" -ge 66 ]; then g="󰃠"
            elif [ "$bri" -ge 33 ]; then g="󰃟"
            else g="󰃞"; fi
            printf '%s\n' "$g"
            ;;
        icon)
            if [ "$bri" -ge 90 ]; then n="bri-full.svg"
            elif [ "$bri" -ge 50 ]; then n="bri-high.svg"
            elif [ "$bri" -ge 30 ]; then n="bri-medium.svg"
            else n="bri-low.svg"; fi
            printf '%s/%s\n' "$iconpath" "$n"
            ;;
    esac
fi#!/bin/bash

# This script displays an appropriate brightness icon according to the brightness level by `xbacklight` command

# Author: purpleleaf
# e-mail: max@ganoia.eu
# Project: https://github.com/purpleleaf/pmt2e
# License: GPL3

# Dependencies: xbacklight dunst

scriptname=`basename $0`
action=""
output=""

die() { echo "$*" 1>&2 ; exit 1; }
help_error_action="Only one action can be chosen between -h -s -u -d"
help_error_output="Only one action can be chosen between -i -f -t"

while getopts ":huds:iftx" opt; do
  case ${opt} in
# allow only one action between help, set, up, down, toggle
    h)
      [ -n "$action" ] && die "${help_error_action}"
      action="help"
	  output="help"
      ;;
    s)
      [ -n "$action" ] && die "${help_error_action}"
      action="set"
      if [[ "$OPTARG" =~ ^[0-9]+$ ]] && [[ "$OPTARG" -ge 0 ]] && [[ "$OPTARG" -le 100 ]]; then
      input_bri="$OPTARG"
      else
        die "error: -s argument is not a valid number" 
      fi
      ;;
    u)
      [ -n "$action" ] && die "${help_error_action}"
      action="up"
      ;;
    d)
      [ -n "$action" ] && die "${help_error_action}"
      action="down"
      ;;
# allow only one option between icon, text or font glyph
    i)
      [ -n "$output" ] && die "${help_error_output}"
      output="icon"
      ;;
    f)
      [ -n "$output" ] && die "${help_error_output}"
      output="glyph"
      ;;
    t)
      [ -n "$output" ] && die "${help_error_output}"
      output="text"
      ;;
    x)
      [ -n "$output" ] && die "${help_error_output}"
      output="nooutput"
      ;;
# require an argument for -s option 
    :)
      die "Option -"$OPTARG" requires an argument"
      ;;
    *)
      die "Invalid option -"$OPTARG""
      ;;
  esac
done

# exit if $action and/or $output are not set
if [[ ! -n "$action" ]] || [[ ! -n "$output" ]]; then
die "$scriptname requires both an action [-h | -s | -u | -d ] and an output [-i | -f | -t] option. \
Please run \"$scriptname -h\" for usage."
fi

show_help () {
  printf -- "\nUsage: $scriptname [ -h | -s | -u | -d ] [ -i | -f | -t ]\n"
  printf -- "\n"
  printf -- "  -h, Show this help message and exit.\n"
  printf -- "  -s, set brightness to the number passed as argument.\n"
  printf -- "  -u, raise brightness.\n"
  printf -- "  -d, lower brightness.\n"
  printf -- "  -i, output an icon path to Tint2.\n"
  printf -- "  -f, output a font glyph instead of icon.\n"
  printf -- "  -t, output text instead of icon.\n"
  printf -- "  -x, no output, for use outside of tint2.\n"
  printf -- "Only one option for both the two option group must be provided.\n"
  printf -- "If -s is selected an integer number (0-100) must be provided.\n"
  printf -- "If -h is selected no other option is required.\n\n"
  exit 0	
}

function send_notification {
    dunstify -i $2 -t 1000 -h string:x-dunst-stack-tag:brightness -u normal "$1%" -h int:value:$1
}

b=$(xbacklight -get)
bri=$(echo $b | awk '{ printf"%0.0f\n", $1 }')

function get_icon {
if [[ "$bri" -gt "90" ]]; then
  icon="/usr/share/pmt2e/icons/bri-full.svg"
elif [[ "$bri" -gt "50" ]]; then
  icon="/usr/share/pmt2e/icons/bri-high.svg"
elif [[ "$bri" -gt "30" ]]; then
  icon="/usr/share/pmt2e/icons/bri-medium.svg"
else
  icon="/usr/share/pmt2e/icons/bri-low.svg"
fi
echo ${icon}
}

function get_glyph {
if [[ ${bri} -ge 66 ]]; then
  glyph="󰃚"
elif [[ ${bri} -ge 33 ]]; then
  glyph="󰃛"
else
  glyph="󰃜"
fi
echo ${glyph} 
}

briicon=$(get_icon)

case ${action} in
  help)
    show_help
    exit
    ;;
  set)
    xbacklight -set "${input_bri}"
    send_notification ${input_bri} ${briicon}
    ;;
  up)
    xbacklight +5
    send_notification ${bri} ${briicon}
    ;;
  down)
    xbacklight -5
    send_notification ${bri} ${briicon}
    ;;
esac

case $output in
  glyph)
    get_glyph
    ;;
  text)
    echo "Bri: ${bri}%"
    ;;
  icon)
    get_icon
    ;;
  nooutput)
    exit 0
    ;;
esac
