#!/bin/sh
# ==============================================================================
# Script Name  : pmbrightness
# Description  : PMT2e Brightness Agent - Support for light, brightnessctl, xbacklight
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : light OR brightnessctl OR xbacklight, jgmenu, dunstify, yad
# Optional     : Nerd font of your choice for font glyph output
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")
lock_file="/tmp/${scriptname}.lock"

# ---------------------------------------------------------
# Error handling & Utilities
# ---------------------------------------------------------
exists() { 
    command -v "$1" >/dev/null 2>&1 
}

show_dialog() {
    # If a lock exists, a window is already open. Return silently.
    if [ -f "$lock_file" ]; then
        return
    fi
    
    # Create the lock
    touch "$lock_file"
    
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0"
    
    # Remove lock when window is closed
    rm -f "$lock_file"
}

die() {
    if [ "$1" = "-y" ]; then
        shift
        if exists yad; then 
            show_dialog "$*" "Brightness Error" "dialog-error"
        else 
            printf '%s\n' "$*" 1>&2
        fi
    else
        printf '%s\n' "$*" 1>&2
    fi
    exit 1
}

show_help() {
    printf "Usage: %s [Action] | [Output]\n\n" "$scriptname"
    printf "PMT2e Brightness Agent - Adjust backlight levels.\n\n"
    printf "ACTIONS (Choose one):\n"
    printf "  -u        Increase brightness by 5%%\n"
    printf "  -d        Decrease brightness by 5%%\n"
    printf "  -s [val]  Set brightness to specific percentage (0-100)\n"
    printf "  -g        Launch external GUI slider (pmgui-scale)\n"
    printf "  -m        Show interactive jgmenu\n"
    printf "  -h        Show this help message and exit\n\n"
    printf "OUTPUT FORMATS:\n"
    printf "  -t        Print text output (Default)\n"
    printf "  -f        Print Nerd Font glyph\n"
    printf "  -i        Print path to brightness SVG icon\n"
    exit 0
}

# ---------------------------------------------------------
# Backlight Backend Detection & Wrappers
# ---------------------------------------------------------
get_backend() {
    if exists light; then 
        BACKEND="light"
    elif exists brightnessctl; then 
        BACKEND="brightnessctl"
    elif exists xbacklight; then 
        BACKEND="xbacklight"
    else 
        BACKEND=""
    fi
}

get_bri() {
    if [ -z "$BACKEND" ]; then
        return 1
    fi

    case "$BACKEND" in
        light)         
            light -G | cut -d'.' -f1 
            ;;
        brightnessctl) 
            brightnessctl -m | cut -d',' -f4 | tr -d '%' 
            ;;
        xbacklight)    
            xbacklight -get | cut -d'.' -f1 
            ;;
    esac
}

set_bri() {
    if [ -z "$BACKEND" ]; then
        die -y "No backlight tool found. Please install 'light', 'brightnessctl', or 'xbacklight'."
    fi

    val="$1"
    mode="$2"

    case "$BACKEND" in
        light)
            if [ "$mode" = "set" ]; then
                light -S "$val"
            elif [ "$mode" = "up" ]; then
                light -A 5
            elif [ "$mode" = "down" ]; then
                light -U 5
            fi
            ;;
        brightnessctl)
            if [ "$mode" = "set" ]; then
                brightnessctl set "$val%"
            elif [ "$mode" = "up" ]; then
                brightnessctl set +5%
            elif [ "$mode" = "down" ]; then
                brightnessctl set 5%-
            fi
            ;;
        xbacklight)
            if [ "$mode" = "set" ]; then
                xbacklight -set "$val"
            elif [ "$mode" = "up" ]; then
                xbacklight -inc 5
            elif [ "$mode" = "down" ]; then
                xbacklight -dec 5
            fi
            ;;
    esac
}

send_notification() {
    if ! exists dunstify; then
        return
    fi

    cur=$(get_bri)
    if [ -z "$cur" ]; then
        return
    fi

    if [ "$cur" -ge 70 ]; then 
        icon="display-brightness-high-symbolic"
    elif [ "$cur" -ge 30 ]; then 
        icon="display-brightness-medium-symbolic"
    else 
        icon="display-brightness-low-symbolic"
    fi

    dunstify -t 1000 -h string:x-dunst-stack-tag:brightness -i "$icon" -h int:value:"$cur" "Brightness: $cur%"
}

# ---------------------------------------------------------
# Execution & Argument Parsing
# ---------------------------------------------------------
action=""
output="text"
input_val=""

err_act="Only one action can be chosen: -u -d -s -g -m"
err_out="Only one output can be chosen: -t -f -i"

while getopts ":huds:mgift" opt; do
    case "${opt}" in
        h) 
            show_help 
            ;;
        u) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="up" 
            ;;
        d) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="down" 
            ;;
        s) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="set"
            input_val="$OPTARG" 
            ;;
        g) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="gui" 
            ;;
        m) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="menu" 
            ;;
        t) 
            output="text" 
            ;;
        f) 
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="glyph" 
            ;;
        i) 
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="icon" 
            ;;
        \?|*) 
            die "Invalid option. Use -h for help." 
            ;;
    esac
done

get_backend

# --- Handle Actions ---
if [ -n "$action" ]; then
    case "$action" in
        gui)
            if exists pmgui-scale; then
                pmgui-scale -b
            else
                die -y "pmgui-scale utility not found."
            fi
            exit 0
            ;;
        menu) 
            menu_list=$(
                printf "Brightness GUI,pmgui-scale -b\n"
                printf "^sep()\n"
                printf "Max (100%%),%s -s 100\n" "$scriptname"
                printf "High (75%%),%s -s 75\n" "$scriptname"
                printf "Medium (50%%),%s -s 50\n" "$scriptname"
                printf "Low (25%%),%s -s 25\n" "$scriptname"
                printf "Night (5%%),%s -s 5\n" "$scriptname"
            )
            printf '%s\n' "$menu_list" | createjgmenu
            exit 0
            ;;
        up|down|set)
            set_bri "$input_val" "$action"
            send_notification
            # Actions do not print output unless requested manually by panel scripts
            exit 0
            ;;
    esac
fi

# --- Handle Continuous Output (Status Bar) ---
bri=$(get_bri)

if [ $? -ne 0 ] || [ -z "$BACKEND" ]; then
    case "$output" in
        text)  printf 'Bri: N/A\n' ;;
        glyph) printf '󰃠 <span color="red">󱈸</span>\n' ;;
        icon)  printf '%s/bri-error.svg\n' "$iconpath" ;;
    esac
    exit 0
fi

case "$output" in
    text)  
        printf 'Bri: %s%%\n' "$bri" 
        ;;
    glyph)
        if [ "$bri" -ge 66 ]; then 
            printf '󰃠\n'
        elif [ "$bri" -ge 33 ]; then 
            printf '󰃟\n'
        else 
            printf '󰃞\n'
        fi
        ;;
    icon)
        if [ "$bri" -ge 90 ]; then 
            printf '%s/bri-full.svg\n' "$iconpath"
        elif [ "$bri" -ge 50 ]; then 
            printf '%s/bri-high.svg\n' "$iconpath"
        elif [ "$bri" -ge 30 ]; then 
            printf '%s/bri-medium.svg\n' "$iconpath"
        else 
            printf '%s/bri-low.svg\n' "$iconpath"
        fi
        ;;
esac
