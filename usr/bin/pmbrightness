#!/bin/sh
# ==============================================================================
# Script Name  : pmbrightness
# Description  : PMT2e Brightness Agent - Strict Verticality Gold Standard
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : light OR brightnessctl OR xbacklight, jgmenu, dunstify, yad
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")
gui_lock="/tmp/${scriptname}_gui.lock"

# ---------------------------------------------------------
# Execution & Argument Parsing (Moved to top for Poll Protection)
# ---------------------------------------------------------
action=""
output="text"
input_val=""

err_act="Only one action can be chosen."
err_out="Only one output can be chosen."

while getopts ":huds:mgift" opt; do
    case "${opt}" in
        h) 
            show_help 
            ;;
        u) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="up" 
            ;;
        d) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="down" 
            ;;
        s) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="set"
            input_val="$OPTARG" 
            ;;
        g) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="gui" 
            ;;
        m) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="menu" 
            ;;
        t) 
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="text" 
            ;;
        f) 
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="glyph" 
            ;;
        i) 
            if [ "$output" != "text" ]; then die "$err_out"; fi
            output="icon" 
            ;;
        \?|*) 
            die "Invalid option. Use -h for help." 
            ;;
    esac
done

# ---------------------------------------------------------
# Utilities & Output Fallbacks
# ---------------------------------------------------------
exists() { 
    command -v "$1" >/dev/null 2>&1 
}

show_help() {
    printf "Usage: %s [Action] | [Output]\n\n" "$scriptname"
    printf "PMT2e Brightness Agent - Adjust backlight levels.\n\n"
    printf "ACTIONS (Choose one):\n"
    printf "  -u        Increase brightness by 5%%\n"
    printf "  -d        Decrease brightness by 5%%\n"
    printf "  -s [val]  Set brightness to specific percentage (0-100)\n"
    printf "  -g        Launch external GUI slider (pmgui-scale)\n"
    printf "  -m        Show interactive jgmenu\n"
    printf "  -h        Show this help message and exit\n\n"
    printf "OUTPUT FORMATS:\n"
    printf "  -t        Print text output (Default)\n"
    printf "  -f        Print Nerd Font glyph\n"
    printf "  -i        Print path to brightness SVG icon\n"
    exit 0
}

print_fallback() {
    case "$output" in
        text)  printf 'Bri: N/A\n' ;;
        glyph) printf '󰃠 <span color="red">󱈸</span>\n' ;;
        icon)  printf '%s/bri-error.svg\n' "$iconpath" ;;
    esac
}

show_dialog() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi
    
    touch "$gui_lock"
    
    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0" \
        --center
    
    rm -f "$gui_lock"
}

die() {
    msg="$1"
    
    # Poll Protection: If polling (no action), fail silently to protect the panel
    if [ -z "$action" ]; then
        print_fallback
        exit 1
    fi

    if [ "$2" = "-y" ]; then
        if exists yad; then 
            show_dialog "$msg" "Brightness Error" "dialog-error"
        else 
            printf '%s\n' "$msg" 1>&2
        fi
    else
        printf '%s\n' "$msg" 1>&2
    fi
    exit 1
}

# ---------------------------------------------------------
# Selective Requirements Check
# ---------------------------------------------------------
# Only check for GUI/Menu tools if an interactive action is requested.
if [ -n "$action" ]; then
    for req in yad jgmenu; do
        if ! exists "$req"; then
            die "Error: dependency '$req' is not installed." "-y"
        fi
    done
fi

# ---------------------------------------------------------
# Backlight Backend Detection & Wrappers
# ---------------------------------------------------------
get_backend() {
    if exists light; then 
        BACKEND="light"
    elif exists brightnessctl; then 
        BACKEND="brightnessctl"
    elif exists xbacklight; then 
        BACKEND="xbacklight"
    else 
        BACKEND=""
    fi
}

get_bri() {
    if [ -z "$BACKEND" ]; then
        return 1
    fi

    case "$BACKEND" in
        light)         
            light -G | cut -d'.' -f1 
            ;;
        brightnessctl) 
            brightnessctl -m | cut -d',' -f4 | tr -d '%' 
            ;;
        xbacklight)    
            xbacklight -get | cut -d'.' -f1 
            ;;
    esac
}

set_bri() {
    if [ -z "$BACKEND" ]; then
        die "No backlight tool found. Please install 'light', 'brightnessctl', or 'xbacklight'." "-y"
    fi

    val="$1"
    mode="$2"

    case "$BACKEND" in
        light)
            if [ "$mode" = "set" ]; then
                light -S "$val"
            elif [ "$mode" = "up" ]; then
                light -A 5
            elif [ "$mode" = "down" ]; then
                light -U 5
            fi
            ;;
        brightnessctl)
            if [ "$mode" = "set" ]; then
                brightnessctl set "${val}%"
            elif [ "$mode" = "up" ]; then
                brightnessctl set +5%
            elif [ "$mode" = "down" ]; then
                brightnessctl set 5%-
            fi
            ;;
        xbacklight)
            if [ "$mode" = "set" ]; then
                xbacklight -set "$val"
            elif [ "$mode" = "up" ]; then
                xbacklight -inc 5
            elif [ "$mode" = "down" ]; then
                xbacklight -dec 5
            fi
            ;;
    esac
}

send_notification() {
    if ! exists dunstify; then
        return
    fi

    cur=$(get_bri)
    if [ -z "$cur" ]; then
        return
    fi

    if [ "$cur" -ge 70 ]; then 
        icon="display-brightness-high-symbolic"
    elif [ "$cur" -ge 30 ]; then 
        icon="display-brightness-medium-symbolic"
    else 
        icon="display-brightness-low-symbolic"
    fi

    dunstify -t 1000 -h string:x-dunst-stack-tag:brightness -i "$icon" -h int:value:"$cur" "Brightness: ${cur}%"
}

get_backend

# ---------------------------------------------------------
# Handle Actions
# ---------------------------------------------------------
if [ -n "$action" ]; then
    case "$action" in
        gui)
            if exists pmgui-scale; then
                pmgui-scale -b
            else
                die "pmgui-scale utility not found." "-y"
            fi
            exit 0
            ;;
        menu) 
            menu_list=$(
                printf "Brightness GUI,pmgui-scale -b\n"
                printf "^sep()\n"
                printf "Max (100%%),%s -s 100\n" "$scriptname"
                printf "High (75%%),%s -s 75\n" "$scriptname"
                printf "Medium (50%%),%s -s 50\n" "$scriptname"
                printf "Low (25%%),%s -s 25\n" "$scriptname"
                printf "Night (5%%),%s -s 5\n" "$scriptname"
            )
            printf '%s\n' "$menu_list" | createjgmenu
            exit 0
            ;;
        up|down|set)
            set_bri "$input_val" "$action"
            send_notification
            exit 0
            ;;
    esac
fi

# ---------------------------------------------------------
# Handle Continuous Output (Status Bar)
# ---------------------------------------------------------
bri=$(get_bri)
backend_err=$?

if [ "$backend_err" -ne 0 ] || [ -z "$BACKEND" ]; then
    print_fallback
    exit 0
fi

case "$output" in
    text)  
        printf 'Bri: %s%%\n' "$bri" 
        ;;
    glyph)
        if [ "$bri" -ge 66 ]; then 
            printf '󰃠\n'
        elif [ "$bri" -ge 33 ]; then 
            printf '󰃟\n'
        else 
            printf '󰃞\n'
        fi
        ;;
    icon)
        if [ "$bri" -ge 90 ]; then 
            printf '%s/bri-full.svg\n' "$iconpath"
        elif [ "$bri" -ge 50 ]; then 
            printf '%s/bri-high.svg\n' "$iconpath"
        elif [ "$bri" -ge 30 ]; then 
            printf '%s/bri-medium.svg\n' "$iconpath"
        else 
            printf '%s/bri-low.svg\n' "$iconpath"
        fi
        ;;
esac
