#!/bin/sh

# Posix compliant script for Arch based systems.
# It can also use custom commands to adapt to other distro.
# Designed for panels and bars like Tint2, Waybar, and SFWBar.
# Authors: Max Franco <purpleleaf at ganoia.eu>
# License: GPL3

# Dependencies: jgmenu, dunstify, createjgmenu, yad (optional)
# Arch and derivatives: pacman-contrib [ yay | paru | trizen | aura ]
# Optional: a Nerd font of your choice for font glyph output


#!/bin/sh
# ==============================================================================
# Script Name  : pmupdater
# Description  : PMT2e Update Agent - Universal checker for Arch and Flatpak
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : pacman-contrib, jgmenu, dunstify, yad
# Optional     : for Arch and derivatives an aur helper  [ yay | paru | trizen | aura ]
# Optional     : Nerd font of your choice for font glyph output
# ==============================================================================

scriptname=$(basename "$0")
gui_lock="/tmp/${scriptname}_gui.lock"

# -------------------------------------------------------------------
# EARLY UTILITIES
# -------------------------------------------------------------------

exists() { 
    command -v "$1" >/dev/null 2>&1 
}

show_dialog() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi

    touch "$gui_lock"

    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0" \
        --center

    rm -f "$gui_lock"
}

die() {
    msg="$1"
    if [ "$2" = "-y" ]; then
        if exists yad; then
            show_dialog "$msg" "Error" "dialog-error"
        else
            printf '%s\n' "$msg" 1>&2
        fi
    else
        printf '%s\n' "$msg" 1>&2
    fi
    exit 1
}

# -------------------------------------------------------------------
# CONFIGURATION & ENVIRONMENT
# -------------------------------------------------------------------

config_dir="$HOME/.config/pmt2e"
config="$config_dir/pmupadater.conf"

terminal_list="xterm $TERMINAL x-terminal-emulator alacritty kitty foot ghostty urxvt rxvt st qterminal gnome-terminal xfce4-terminal mate-terminal terminology"

custom_check_cmd=""
custom_upgrade_cmd=""
custom_clean_cmd=""
refresh_cmd=""
arch_use_helper="false"
enable_flatpak="false"
waybar_signal="8"
sfwbar_signal="4"

terminal=""
for term in $terminal_list; do
    if exists "$term"; then 
        terminal="$term"
        break
    fi
done

if [ -f "$config" ]; then
    while IFS='=' read -r key val; do
        case "$key" in
            \#*|"") 
                continue 
                ;;
        esac

        clean_val=$(printf '%s' "$val" | tr -d '"' | tr -d "'")

        case "$key" in
            terminal)        
                terminal="$clean_val" 
                ;;
            check_cmd)       
                custom_check_cmd="$clean_val" 
                ;;
            upgrade_cmd)     
                custom_upgrade_cmd="$clean_val" 
                ;;
            clean_cmd)       
                custom_clean_cmd="$clean_val" 
                ;;
            refresh_cmd)     
                refresh_cmd="$clean_val" 
                ;;
            waybar_signal)   
                waybar_signal="$clean_val" 
                ;;
            sfwbar_signal)   
                sfwbar_signal="$clean_val" 
                ;;
            arch_use_helper)
                case "$(printf '%s' "$clean_val" | tr '[:upper:]' '[:lower:]')" in
                    1|true|yes|y|on) 
                        arch_use_helper="true" 
                        ;;
                    *) 
                        arch_use_helper="false" 
                        ;;
                esac
                ;;
            enable_flatpak)
                case "$(printf '%s' "$clean_val" | tr '[:upper:]' '[:lower:]')" in
                    1|true|yes|y|on) 
                        enable_flatpak="true" 
                        ;;
                    *) 
                        enable_flatpak="false" 
                        ;;
                esac
                ;;
        esac
    done < "$config"
else
    if [ ! -d "$config_dir" ]; then
        mkdir -p "$config_dir"
    fi
    {
        if [ -n "$terminal" ]; then
            printf 'terminal=%s\n' "$terminal"
        fi
        printf 'waybar_signal=%s\n' "$waybar_signal"
        printf 'sfwbar_signal=%s\n' "$sfwbar_signal"
        printf 'arch_use_helper=false\n'
        printf 'enable_flatpak=false\n'
    } > "$config"
fi

if [ -z "$terminal" ]; then
    die "No available terminal found." "-y"
fi

get_aur_helper() {
    if [ -n "$aur_helper" ]; then 
        return
    fi
    if exists yay; then 
        aur_helper="yay"
    elif exists paru; then 
        aur_helper="paru"
    elif exists trizen; then 
        aur_helper="trizen"
    elif exists aura; then 
        aur_helper="aura"
    else 
        aur_helper="pacman"
    fi
}

# -------------------------------------------------------------------
# PARSE OPTIONS
# -------------------------------------------------------------------

action=""
output="text" 

err_act="Only one action can be chosen: -h -u -U -m -n -p -e"
err_out="Only one output can be chosen: -i -f -t"

while getopts ":huUmniftpe" opt; do
    case "${opt}" in
        h)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="help"
            ;;
        u)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="check"
            ;;
        U)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="upgrade"
            ;;
        m)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="menu"
            ;;
        n)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="notify"
            ;;
        p)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="toggle_flatpak"
            ;;
        e)
            if [ -n "$action" ]; then 
                die "$err_act"
            fi
            action="clean"
            ;;
        i)
            if [ "$output" != "text" ]; then 
                die "$err_out"
            fi
            output="icon"
            ;;
        f)
            if [ "$output" != "text" ]; then 
                die "$err_out"
            fi
            output="glyph"
            ;;
        t)
            output="text"
            ;;
        \?|*)
            die "Invalid option. Use -h for help." 
            ;;
    esac
done

if [ -z "$action" ]; then
    die "$scriptname requires an action [-u | -U | -m | -n | -e | -p]. Run $scriptname -h for help."
fi

# -------------------------------------------------------------------
# CORE FUNCTIONS
# -------------------------------------------------------------------

send_refresh_signals() {
    if [ -n "$refresh_cmd" ]; then
        eval "$refresh_cmd"
        return
    fi

    if pgrep -x tint2 >/dev/null; then
        pkill -USR1 -x tint2
    fi

    if pgrep -x waybar >/dev/null; then
        pkill -RTMIN+"$waybar_signal" -x waybar
    fi

    if pgrep -x sfwbar >/dev/null; then
        pkill -RTMIN+"$sfwbar_signal" -x sfwbar
    fi
}

show_help() {
    printf "Usage: %s -[Action] [-[Output]]\n\n" "$scriptname"
    printf "A universal update checker and updater for status bars (Waybar, tint2, sfwbar).\n"
    printf "By default, if no output format is specified, -t (text) is used.\n\n"
    
    printf "ACTIONS (Choose exactly one):\n"
    printf "  -u    Check for updates and print the status\n"
    printf "  -U    Launch the terminal and execute the system upgrade\n"
    printf "  -n    Trigger a desktop notification of available updates\n"
    printf "  -m    Show an interactive jgmenu with update options\n"
    printf "  -e    Clean package cache\n"
    printf "  -p    Toggle Flatpak support\n"
    printf "  -h    Show this help message and exit\n\n"
    
    printf "OUTPUT FORMATS (Optional, affects -u and -U):\n"
    printf "  -t    Text output (e.g., 'Upd: 5') [DEFAULT]\n"
    printf "  -f    Glyph/Font icon output (e.g., 󱆢)\n"
    printf "  -i    Image icon output (SVG paths)\n\n"
    
    printf "EXAMPLES:\n"
    printf "  %s -u        # Check updates and output as text (default)\n" "$scriptname"
    printf "  %s -u -f     # Check updates and output as glyph\n" "$scriptname"
    printf "  %s -m        # Open the menu (output flags are ignored)\n" "$scriptname"
    
    exit 0
}

check_reboot() {
    reboot_required="false"
    if [ -f /var/run/reboot-required ]; then 
        reboot_required="true"
    elif exists needs-restarting; then
        if ! needs-restarting -r >/dev/null 2>&1; then
            reboot_required="true"
        fi
    elif [ ! -d "/lib/modules/$(uname -r)" ]; then 
        reboot_required="true"
    fi
}

find_updates() {
    updates=""
    current_time=$(date +%s)
    sync_marker="/tmp/pmu_sync_marker"
    custom_cache="/tmp/pmu_custom_cache"
    CHECK_INTERVAL=600 

    last_sync=$(cat "$sync_marker" 2>/dev/null || echo 0)
    cooldown_active="false"
    if [ $((current_time - last_sync)) -lt "$CHECK_INTERVAL" ]; then
        cooldown_active="true"
    fi

    if exists pacman; then
        get_aur_helper
        if [ "$cooldown_active" = "true" ]; then
            updates=$(LC_ALL=C checkupdates -n --nocolor 2>/dev/null | sed 's/ .*//')
        else
            printf '%s' "$current_time" > "$sync_marker"
            if [ "$arch_use_helper" = "true" ]; then
                updates=$(LC_ALL=C $aur_helper -Qu 2>/dev/null | sed 's/ .*//')
            else
                updates=$(LC_ALL=C checkupdates --nocolor 2>/dev/null | sed 's/ .*//')
            fi
            
            if [ $? -ne 0 ]; then
                rm -f "$sync_marker"
            fi
        fi
        
        aur_upd=$($aur_helper -Qu -a 2>/dev/null)
        if [ -n "$aur_upd" ]; then
            if [ -n "$updates" ]; then
                updates=$(printf '%s\n%s' "$updates" "$aur_upd")
            else
                updates="$aur_upd"
            fi
        fi
    elif [ -n "$custom_check_cmd" ]; then
        if [ "$cooldown_active" = "true" ] && [ -f "$custom_cache" ]; then
            updates=$(cat "$custom_cache")
        else
            printf '%s' "$current_time" > "$sync_marker"
            updates=$(sh -c "$custom_check_cmd" 2>/dev/null)
            printf '%s' "$updates" > "$custom_cache"
            
            if [ $? -ne 0 ]; then
                rm -f "$sync_marker"
            fi
        fi
    fi

    if [ "$enable_flatpak" = "true" ]; then
        if exists flatpak; then
            f_upd=$(LC_ALL=C flatpak remote-ls --updates --columns=application 2>/dev/null)
            if [ -n "$f_upd" ]; then
                if [ -n "$updates" ]; then
                    updates=$(printf '%s\n%s' "$updates" "$f_upd")
                else
                    updates="$f_upd"
                fi
            fi
        fi
    fi

    num_upd=$(printf '%s\n' "$updates" | grep -c '[^ ]')
}

# -------------------------------------------------------------------
# ACTION HANDLERS
# -------------------------------------------------------------------

do_check() {
    l_output="$1"
    
    if [ "$l_output" = "text" ]; then 
        printf "Checking...\n"
    elif [ "$l_output" = "glyph" ]; then 
        printf "󰂪\n"
    elif [ "$l_output" = "icon" ]; then 
        printf "/usr/share/pmt2e/icons/refresh.svg\n"
    fi

    find_updates
    check_reboot

    if [ "$l_output" = "text" ]; then
        if [ "$reboot_required" = "true" ]; then
            if [ "$num_upd" -gt 0 ]; then
                printf " Upd: %d [Reboot]\n" "$num_upd"
            else
                printf " Reboot Required\n"
            fi
        else
            if [ "$num_upd" -gt 0 ]; then
                printf " Upd: %d\n" "$num_upd"
            else
                printf " Up-to-date\n"
            fi
        fi
    elif [ "$l_output" = "glyph" ]; then
        if [ "$reboot_required" = "true" ]; then
            if [ "$num_upd" -gt 0 ]; then
                printf "󱆢 <span foreground='#ff4444'>●</span> 󰑓\n"
            else
                printf "󰑓\n"
            fi
        else
            if [ "$num_upd" -gt 0 ]; then
                printf "󱆢 <span foreground='#ff4444'>●</span>\n"
            else
                printf "󰕥\n"
            fi
        fi
    elif [ "$l_output" = "icon" ]; then
        if [ "$reboot_required" = "true" ]; then
            printf "/usr/share/pmt2e/icons/reboot.svg\n"
        elif [ "$num_upd" -gt 0 ]; then
            printf "/usr/share/pmt2e/icons/system-update-notify.svg\n"
        else
            printf "/usr/share/pmt2e/icons/system-update.svg\n"
        fi
    fi
}

do_upgrade() {
    l_output="$1"

    if [ "$l_output" = "glyph" ]; then 
        printf "󰂪\n"
    elif [ "$l_output" = "text" ]; then  
        printf "Updating..\n"
    elif [ "$l_output" = "icon" ]; then  
        printf "/usr/share/pmt2e/icons/arch-icon-notify.svg\n"
    fi

    if exists pacman; then
        get_aur_helper
        if [ "$(id -u)" -ne 0 ] && [ "$aur_helper" = "pacman" ]; then
            upgrade_cmd="sudo pacman -Syu"
        else
            upgrade_cmd="${aur_helper} -Syu"
        fi
    elif [ -n "$custom_upgrade_cmd" ]; then
        upgrade_cmd="$custom_upgrade_cmd"
    fi

    if [ "$enable_flatpak" = "true" ]; then
        if exists flatpak; then
            upgrade_cmd="$upgrade_cmd; flatpak update"
        fi
    fi

    if [ -n "$upgrade_cmd" ]; then
        $terminal -e sh -c "$upgrade_cmd; rm -f /tmp/pmu_sync_marker /tmp/pmu_custom_cache; printf '\nDone. Enter... '; read dummy"
        send_refresh_signals
    fi
}

do_notify() {
    find_updates
    if [ -n "$updates" ]; then
        printf '%s\n' "$updates" | yad --title="Pending Updates: $num_upd" \
            --window-icon="/usr/share/pmt2e/icons/system-update-notify.svg" \
            --list --no-headers --column="Packages" \
            --width=350 --height=500 --center \
            --button="Close:0" --button="Upgrade Now:1"
        if [ "$?" -eq 1 ]; then
            do_upgrade "text"
        fi
    fi
}

do_clean() {
    if exists pacman; then 
        clean_cmd="sudo pacman -Sc"
    elif [ -n "$custom_clean_cmd" ]; then 
        clean_cmd="$custom_custom_clean_cmd"
    fi
    
    if [ -n "$clean_cmd" ]; then
        $terminal -e sh -c "$clean_cmd; printf '\nDone. Enter... '; read dummy"
    fi
}

do_toggle_flatpak() {
    if [ "$enable_flatpak" = "true" ]; then 
        val="false"
    else 
        val="true"
    fi
    
    sed -i "s/^enable_flatpak=.*/enable_flatpak=\"$val\"/" "$config"
    send_refresh_signals
}

show_menu() {
    if [ "$output" = "text" ]; then 
        flag="t"
    elif [ "$output" = "glyph" ]; then 
        flag="f"
    else 
        flag="i"
    fi

    menu_list=$(
        printf "Check updates,%s -u -%s\n" "$scriptname" "$flag"
        printf "Show updates,%s -n -%s\n" "$scriptname" "$flag"
        printf "Upgrade,%s -U -%s\n" "$scriptname" "$flag"
        if exists pacman || [ -n "$custom_clean_cmd" ]; then
            printf "Empty Cache,%s -e -%s\n" "$scriptname" "$flag"
        fi
        if exists flatpak; then
            if [ "$enable_flatpak" = "true" ]; then 
                txt="Disable Flatpak"
            else 
                txt="Enable Flatpak"
            fi
            printf "%s,%s -p -%s\n" "$txt" "$scriptname" "$flag"
        fi
    )
    printf '%s\n' "$menu_list" | createjgmenu
}

# -------------------------------------------------------------------
# EXECUTION LOGIC
# -------------------------------------------------------------------

case "$action" in
    help)
        show_help
        ;;
    check|upgrade)
        if [ "$action" = "check" ]; then
            do_check "$output"
        else
            do_upgrade "$output"
        fi
        ;;
    *)
        case "$action" in
            notify)         
                do_notify 
                ;;
            menu)           
                show_menu 
                ;;
            clean)          
                do_clean 
                ;;
            toggle_flatpak) 
                do_toggle_flatpak 
                ;;
        esac
        ;;
esac
