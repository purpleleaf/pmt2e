#!/bin/sh
# Simple jgmenu CSV helper
# Author: purpleleaf <max at ganoia dot eu>
# POSIX sh compatible utility to create jgmenus
# Dependencies: jgmenu, yad
# Rules: one comma per item (Label,command). Double quotes are forbidden in labels.

show_error() {
    msg="$1"
    if command -v yad >/dev/null 2>&1; then
        yad --form --field="$msg:LBL" \
            --title="CreateJgmenu Error" \
            --window-icon="dialog-error" \
            --width="500" --center
    else
        printf '%s\n' "$msg" 1>&2
    fi
}

die() {
    show_error "$1"
    exit "${2:-1}"
}

show_help() {
    printf '\n'
    printf '%s\n' "Usage: $0 -c config_file | -m menu_file | -h | list of menu items"
    printf '\n'
    printf '%s\n' 'Rules (simple):'
    printf '%s\n' '  - Each menu item must contain exactly one comma: Label,/path/to/command'
    printf '%s\n' '  - Double quotes (") are not allowed inside labels. Commands may contain quotes.'
    printf '%s\n' '  - Separator tokens: ^sep or ^sep(text) (use them as whole items).'
    printf '%s\n' '  - Blank lines and lines starting with # are ignored.'
    printf '\n'
    printf '%s\n' 'Input Methods:'
    printf '%s\n' '  1. Arguments: "Label,cmd" "Label 2,cmd2"'
    printf '%s\n' '  2. Pipe:      printf "Item,cmd\nItem2,cmd2" | createjgmenu'
    printf '%s\n' '  3. File:      -m menu.txt'
    printf '\n'
    exit 0
}

# Optimized validation: Uses shell-internal logic instead of sed for speed
validate_csv() {
    raw=$1
    # POSIX way to trim leading/trailing whitespace without calling 'sed'
    line=$(printf '%s' "$raw")
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"

    [ -z "$line" ] && return 0
    case "$line" in \#*) return 0 ;; esac
    case "$line" in ^sep*) return 0 ;; esac

    case "$line" in
        *,*,*) die "invalid entry \"$raw\" — too many commas." ;;
        *,*)
            label=${line%%,*}
            cmd=${line#*,}
            [ -z "$label" ] && die "empty label in \"$raw\""
            [ -z "$cmd" ] && die "empty command in \"$raw\""
            case "$label" in *\"*|*\'*) die "quotes are not allowed inside label: \"$raw\"" ;; esac
            # Internal unescape: faster than 'sed s/\\"/"/g'
            # Note: cmd stays as is, jgmenu handles quotes in commands well
            return 0
            ;;
        *) die "invalid entry \"$raw\" — expected Label,command or separator" ;;
    esac
}

menu_items=""
maintain_config=false
maintain_menu=false
config_file=""
menu_file=""

# 1. Option Parsing
while [ "$#" -gt 0 ]; do
    case "$1" in
        -h|--help) show_help ;;
        -c|--config)
            [ -z "$2" ] && die 'option -c requires an argument' 2
            config_file="$2"; maintain_config=true; shift 2 ;;
        -m|--menu)
            [ -z "$2" ] && die 'option -m requires an argument' 2
            menu_file="$2"; maintain_menu=true; shift 2 ;;
        *)
            if [ -z "$menu_file" ]; then
                validate_csv "$1"
                [ -z "$menu_items" ] && menu_items="$1" || menu_items="$menu_items
$1"
            fi
            shift 1 ;;
    esac
done

# 2. STDIN Handler
if [ -z "$menu_items" ] && [ -z "$menu_file" ] && [ ! -t 0 ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        validate_csv "$line"
        [ -z "$menu_items" ] && menu_items="$line" || menu_items="$menu_items
$line"
    done
fi

# 3. Path expansion for ~/
case $menu_file in ~/*) menu_file="$HOME/${menu_file#~/}" ;; esac
case $config_file in ~/*) config_file="$HOME/${config_file#~/}" ;; esac

# 4. Config Creation
if [ -z "$config_file" ]; then
    config_file=$(mktemp /tmp/jgmenu-config.XXXXXXXXXX) || die 'mktemp failed'
    cat <<EOF >"${config_file}"
stay_alive=0
tint2_look=1
position_mode=ipc
menu_width=40
menu_border=1
item_height=20
font=Sans 10
icon_size=0
EOF
else
    [ -f "$config_file" ] || die "config file \"$config_file\" does not exist"
    [ -r "$config_file" ] || die "config file \"$config_file\" is not readable"
fi

# 5. Menu Creation
if [ -z "$menu_file" ]; then
    menu_file=$(mktemp /tmp/jgmenu-menu.XXXXXXXXXX) || die 'mktemp failed'
    if [ -n "${menu_items}" ]; then
        # Perform final unescape for the whole file at once
        printf '%s\n' "${menu_items}" | sed 's/\\"/"/g' > "${menu_file}"
    fi
    maintain_menu=false
fi

[ ! -s "${menu_file}" ] && die 'file did not contain any menu items'

# Double check the file contents (restored your logic)
while IFS= read -r raw_line || [ -n "$raw_line" ]; do
    validate_csv "$raw_line"
done < "$menu_file"

# 6. Execution & Cleanup
cleanup() {
    [ "${maintain_menu}" != "true" ] && [ -f "${menu_file}" ] && rm -f -- "${menu_file}" 2>/dev/null
    [ "${maintain_config}" != "true" ] && [ -f "${config_file}" ] && rm -f -- "${config_file}" 2>/dev/null
}
trap cleanup EXIT INT TERM

jgmenu --config-file="${config_file}" --csv-file="${menu_file}"
