#!/bin/sh
# ==============================================================================
# Script Name  : pmweather
# Description  : PMT2e Weather Agent - Unified and POSIX compliant
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Credits      : nilsonmorale (ywtray settings concept) - https://github.com/Dimorld/ywtray
#                John D. Martin III (original open weather parser) - https://github.com/jdmar3/galo.sh
# Icons by     : Amchart (https://www.amcharts.com)
#                JoshuaKimsey (https://github.com/JoshuaKimsey/amCharts-SVG-Icons-Additions)
# Dependencies : curl, jq, yad, dunstify, jgmenu, pkill
# ==============================================================================

iconpath="/usr/share/pmt2e/wheather_icons"
scriptname=$(basename "$0")
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmweather.conf"
lock_file="/tmp/${scriptname}.lock"

# ---------------------------------------------------------
# Utilities & Requirements Check
# ---------------------------------------------------------
exists() { 
    command -v "$1" >/dev/null 2>&1 
}

die() {
    printf '%s\n' "$*" 1>&2
    exit 1
}

for req in curl jq yad dunstify jgmenu pkill; do
    if ! exists "$req"; then
        die "Error: dependency '$req' is not installed."
    fi
done

sys_lang=$(printf '%s' "${LANG:-en}" | cut -d_ -f1 | cut -d. -f1)

# Default panel signals (Must be distinct from pmupdater)
waybar_signal="9"
sfwbar_signal="5"
refresh_cmd=""

show_help() {
    printf "==============================================================\n"
    printf " %s - PMT2e Weather Agent\n" "$scriptname"
    printf "==============================================================\n"
    printf "Usage: %s [ACTION] [OUTPUT_FORMAT]\n\n" "$scriptname"
    printf "DESCRIPTION:\n"
    printf "  A unified, POSIX-compliant weather agent that fetches\n"
    printf "  forecasts, displays notifications, and provides a GUI.\n\n"
    printf "ACTIONS:\n"
    printf "  -n    Show desktop notification with current weather info.\n"
    printf "  -F    Show 3-day forecast in a rich YAD GUI table.\n"
    printf "  -c    Open the configuration GUI to set location and units.\n"
    printf "  -m    Show the jgmenu context menu.\n"
    printf "  -h    Show this extensive help message and exit.\n\n"
    printf "OUTPUT FORMATS (Default is -i):\n"
    printf "  -t    Print the weather description as plain text.\n"
    printf "  -g    Print the Nerd Font weather glyph.\n"
    printf "  -i    Print the full path to the SVG weather icon.\n\n"
    printf "EXAMPLES:\n"
    printf "  %s -n          # Show a weather notification\n" "$scriptname"
    printf "  %s -c          # Configure your city/location\n" "$scriptname"
    printf "  %s -t          # Print textual description\n" "$scriptname"
    printf "==============================================================\n"
    exit 0
}

send_refresh_signals() {
    if [ -n "$refresh_cmd" ]; then
        eval "$refresh_cmd"
        return
    fi

    if pgrep -x tint2 >/dev/null; then
        pkill -USR1 -x tint2
    fi

    if pgrep -x waybar >/dev/null; then
        pkill -RTMIN+"$waybar_signal" -x waybar
    fi

    if pgrep -x sfwbar >/dev/null; then
        pkill -RTMIN+"$sfwbar_signal" -x sfwbar
    fi
}

# ---------------------------------------------------------
# Configuration & Geocoding
# ---------------------------------------------------------
search_location() {
    search_term="$1"
    results=$(curl -s -A "PMT2e-Weather-Agent" \
        "https://nominatim.openstreetmap.org/search?q=${search_term}&format=json&limit=5")
    
    if [ -z "$results" ] || [ "$results" = "[]" ]; then
        return 1
    fi
    printf '%s' "$results" | jq -r '.[] | "\(.lat)|\(.lon)|\(.display_name)"'
}

do_config() {
    if [ -f "$lock_file" ]; then 
        return
    fi
    touch "$lock_file"

    if [ -f "$config_file" ]; then 
        . "$config_file"
    fi

    while true; do
        new_configs=$(yad --title="Weather Settings" \
            --window-icon="${iconpath}/cloudy.svg" \
            --form --columns=2 \
            --field="City/Location:" "${location}" \
            --field="Temp Unit:CB" "${temp_unit:-celsius}!celsius!fahrenheit" \
            --field="Icon Style:CB" "${icon_type:-coloured}!coloured!monochrome!glyphs" \
            --field='!gtk-find!Search':BTN "sh -c 'exit 0'" \
            --field='!gtk-help!Location':BTN "yad --info --text='Enter city and Search. Pick from list.' --borders=15" \
            --button="Save:0" --button="Cancel:1" \
            --borders=15)

        if [ $? -ne 0 ]; then 
            break
        fi

        loc=$(printf '%s' "$new_configs" | cut -d'|' -f1)
        t_unit=$(printf '%s' "$new_configs" | cut -d'|' -f2)
        i_style=$(printf '%s' "$new_configs" | cut -d'|' -f3)

        search_results=$(search_location "$loc")
        if [ $? -ne 0 ]; then
            yad --error --text="Location not found." --borders=15
            continue
        fi

        selection=$(printf '%s' "$search_results" | yad --list \
            --title="Select Exact Location" \
            --column="Lat" --column="Lon" --column="Address" \
            --width=750 --height=350 --borders=15)

        if [ $? -eq 0 ] && [ -n "$selection" ]; then
            lat=$(printf '%s' "$selection" | cut -d'|' -f1)
            lon=$(printf '%s' "$selection" | cut -d'|' -f2)
            
            mkdir -p "$config_dir"
            cat <<EOF > "$config_file"
latitude="$lat"
longitude="$lon"
location="$loc"
temp_unit="$t_unit"
icon_type="$i_style"
windspeed_unit="kmh"
precipitation_unit="mm"
waybar_signal="${waybar_signal}"
sfwbar_signal="${sfwbar_signal}"
EOF
            yad --info --text="Saved: $loc" --borders=15
            send_refresh_signals
            break
        fi
    done
    rm -f "$lock_file"
}

# ---------------------------------------------------------
# Weather Engine Mapping
# ---------------------------------------------------------
get_info_by_code() {
    code="$1"
    day_state="$2"
    
    case "$code" in
        0) 
            if [ "$day_state" = "1" ]; then
                if [ "$sys_lang" = "it" ]; then
                    d="Sereno"
                else
                    d="Clear sky"
                fi
                echo "clear-day.svg||$d"
            else
                if [ "$sys_lang" = "it" ]; then
                    d="Sereno"
                else
                    d="Clear sky"
                fi
                echo "clear-night.svg||$d"
            fi
            ;;
        1|2|3)
            if [ "$sys_lang" = "it" ]; then
                d="Nuvoloso"
            else
                d="Cloudy"
            fi
            
            if [ "$day_state" = "1" ]; then
                echo "cloudy-2-day.svg||$d"
            else
                echo "cloudy-2-night.svg||$d"
            fi
            ;;
        45|48)
            if [ "$sys_lang" = "it" ]; then
                d="Nebbia"
            else
                d="Fog"
            fi
            echo "fog.svg||$d"
            ;;
        51|53|55|61|63|65)
            if [ "$sys_lang" = "it" ]; then
                d="Pioggia"
            else
                d="Rain"
            fi
            echo "rainy-3.svg||$d"
            ;;
        71|73|75)
            if [ "$sys_lang" = "it" ]; then
                d="Neve"
            else
                d="Snow"
            fi
            echo "snowy-3.svg||$d"
            ;;
        *)
            if [ "$sys_lang" = "it" ]; then
                d="Sconosciuto"
            else
                d="Unknown"
            fi
            echo "default-no.svg|󰨹|$d"
            ;;
    esac
}

# ---------------------------------------------------------
# Execution Logic
# ---------------------------------------------------------
action=""
output_format="icon"
err_act="Only one action can be chosen: -n -F -c -m"
err_out="Only one output can be chosen: -t -g -i"

while getopts ":nFmtgich" opt; do
    case ${opt} in
        h) 
            show_help 
            ;;
        n) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="notify" 
            ;;
        F) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="forecast" 
            ;;
        c) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="config" 
            ;;
        m) 
            if [ -n "$action" ]; then die "$err_act"; fi
            action="menu" 
            ;;
        t) 
            if [ "$output_format" != "icon" ]; then die "$err_out"; fi
            output_format="text" 
            ;;
        g) 
            if [ "$output_format" != "icon" ]; then die "$err_out"; fi
            output_format="glyph" 
            ;;
        i) 
            output_format="icon" 
            ;;
        \?|*) 
            die "Argument error. Use -h for help." 
            ;;
    esac
done

if [ -f "$config_file" ]; then 
    . "$config_file"
else
    if [ "$action" != "config" ] && [ "$action" != "menu" ] && [ "$action" != "help" ]; then
        do_config
        if [ -f "$config_file" ]; then
            . "$config_file"
        else
            exit 1
        fi
    fi
fi

case "$action" in
    config) 
        do_config 
        ;;
    menu) 
        printf "Show Forecast,%s -F\nNotification Info,%s -n\nSettings,%s -c\n" "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;
    forecast|notify|"")
        if [ -z "$latitude" ]; then
            die "Incomplete configuration. Run pmweather -c first."
        fi

        weather_data=$(curl -s "https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m,is_day,precipitation&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,sunrise,sunset&temperature_unit=${temp_unit}&timezone=auto&forecast_days=3")

        if [ -z "$weather_data" ]; then 
            die "Error: Unable to connect to weather API."
        fi

        if [ "$action" = "forecast" ]; then
            (
                i=0
                while [ $i -le 2 ]; do
                    f_date=$(printf '%s' "$weather_data" | jq -r ".daily.time[$i]")
                    f_max=$(printf '%s' "$weather_data" | jq -r ".daily.temperature_2m_max[$i]")
                    f_min=$(printf '%s' "$weather_data" | jq -r ".daily.temperature_2m_min[$i]")
                    f_code=$(printf '%s' "$weather_data" | jq -r ".daily.weather_code[$i]")
                    f_prec=$(printf '%s' "$weather_data" | jq -r ".daily.precipitation_probability_max[$i]")
                    
                    f_info=$(get_info_by_code "$f_code" "1")
                    f_icon_file=$(printf '%s' "$f_info" | cut -d'|' -f1)
                    f_desc=$(printf '%s' "$f_info" | cut -d'|' -f3)
                    
                    sub_dir=""
                    if [ "$icon_type" = "monochrome" ]; then
                        sub_dir="dark/"
                    fi

                    printf '%s/%s%s\n' "$iconpath" "$sub_dir" "$f_icon_file"
                    printf '%s\n' "$f_date"
                    printf '%s\n' "$f_desc"
                    printf '%s / %s°\n' "$f_min" "$f_max"
                    printf '%s%%\n' "$f_prec"
                    
                    i=$((i + 1))
                done
            ) | yad --list \
                --title="Weather Forecast: ${location}" \
                --width=650 --height=400 --borders=15 \
                --column="":IMG --column="Date" --column="Status" --column="Temp. Min/Max" --column="Rain Prob." \
                --no-selection --button="Close:0"
        else
            curr_code=$(printf '%s' "$weather_data" | jq -r '.current.weather_code')
            curr_is_day=$(printf '%s' "$weather_data" | jq -r '.current.is_day')

            info_str=$(get_info_by_code "$curr_code" "$curr_is_day")
            icon_file=$(printf '%s' "$info_str" | cut -d'|' -f1)
            glyph=$(printf '%s' "$info_str" | cut -d'|' -f2)
            desc=$(printf '%s' "$info_str" | cut -d'|' -f3)

            if [ "$action" = "notify" ]; then
                curr_temp=$(printf '%s' "$weather_data" | jq -r '.current.temperature_2m')
                curr_hum=$(printf '%s' "$weather_data" | jq -r '.current.relative_humidity_2m')
                curr_wind=$(printf '%s' "$weather_data" | jq -r '.current.wind_speed_10m')
                curr_prec=$(printf '%s' "$weather_data" | jq -r '.current.precipitation')
                
                if [ "$sys_lang" = "it" ]; then
                    lbl_hum="Umidità"
                    lbl_wind="Vento"
                    lbl_prec="Pioggia"
                else
                    lbl_hum="Humidity"
                    lbl_wind="Wind"
                    lbl_prec="Rain"
                fi

                dunstify -i "${iconpath}/${icon_file}" "Weather: ${location}" \
                    "Temp: ${curr_temp}° (${desc})\n${lbl_hum}: ${curr_hum}%\n${lbl_wind}: ${curr_wind} km/h\n${lbl_prec}: ${curr_prec} mm"
            else
                case "$output_format" in
                    text)  
                        printf '%s\n' "$desc" 
                        ;;
                    glyph) 
                        printf '%s\n' "$glyph" 
                        ;;
                    icon)  
                        sub=""
                        if [ "$icon_type" = "monochrome" ]; then
                            sub="dark/"
                        fi
                        printf '%s/%s%s\n' "$iconpath" "$sub" "$icon_file" 
                        ;;
                esac
            fi
        fi
        ;;
esac
