#!/bin/sh
# ==============================================================================
# Script Name  : pmweather
# Description  : PMT2e Weather Agent - Unified, POSIX compliant & Multilingual
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Credits      : nilsonmorale (ywtray settings concept) - https://github.com/Dimorld/ywtray
#                John D. Martin III (original open weather parser) - https://github.com/jdmar3/galo.sh
# Icons by     : Amchart (https://www.amcharts.com)
#                JoshuaKimsey (https://github.com/JoshuaKimsey/amCharts-SVG-Icons-Additions)
# Dependencies : curl, jq, yad, dunstify, jgmenu, pkill
# ==============================================================================

iconpath="/usr/share/pmt2e/weather_icons"
translation_file="/usr/share/pmt2e/weather_map.json"
scriptname=$(basename "$0")
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pmt2e"
config_file="$config_dir/pmweather.conf"
gui_lock="/tmp/${scriptname}_gui.lock"

# ---------------------------------------------------------
# Utilities & Requirements Check
# ---------------------------------------------------------
exists() {
    command -v "$1" >/dev/null 2>&1
}

show_dialog() {
    if [ -f "$gui_lock" ]; then
        find "/tmp" -name "$(basename "$gui_lock")" -mmin +1 -delete
        if [ -f "$gui_lock" ]; then
            return
        fi
    fi

    touch "$gui_lock"

    yad --title="$2" \
        --text="$1" \
        --image="$3" \
        --window-icon="$3" \
        --borders=15 \
        --button="Close:0" \
        --center

    rm -f "$gui_lock"
}

die() {
    msg="$1"
    if [ "$2" = "-y" ]; then
        if exists yad; then
            show_dialog "$msg" "Weather Error" "dialog-error"
        else
            printf '%s\n' "$msg" 1>&2
        fi
    else
        printf '%s\n' "$msg" 1>&2
    fi
    exit 1
}

for req in curl jq yad dunstify jgmenu pkill; do
    if ! exists "$req"; then
        die "Error: dependency '$req' is not installed." "-y"
    fi
done

sys_lang=$(printf '%s' "${LANG:-en}" | cut -d_ -f1 | cut -d. -f1)

# Default panel signals
waybar_signal="10"
sfwbar_signal="6"
refresh_cmd=""

show_help() {
    printf "==============================================================\n"
    printf " %s - PMT2e Weather Agent\n" "$scriptname"
    printf "==============================================================\n"
    printf "Usage: %s [ACTION] [OUTPUT_FORMAT]\n\n" "$scriptname"
    printf "DESCRIPTION:\n"
    printf "  A multilingual weather agent using Open-Meteo API.\n\n"
    printf "ACTIONS:\n"
    printf "  -n    Show desktop notification.\n"
    printf "  -F    Show 3-day forecast GUI.\n"
    printf "  -c    Open configuration GUI.\n"
    printf "  -m    Show context menu.\n"
    printf "  -h    Show help.\n\n"
    printf "OUTPUT FORMATS:\n"
    printf "  -t    Plain text description.\n"
    printf "  -g    Nerd Font glyph.\n"
    printf "  -i    Full path to SVG icon.\n"
    exit 0
}

send_refresh_signals() {
    if [ -n "$refresh_cmd" ]; then
        eval "$refresh_cmd"
        return
    fi

    if pgrep -x tint2 >/dev/null; then
        pkill -USR1 -x tint2
    fi

    if pgrep -x waybar >/dev/null; then
        pkill -RTMIN+"$waybar_signal" -x waybar
    fi

    if pgrep -x sfwbar >/dev/null; then
        pkill -RTMIN+"$sfwbar_signal" -x sfwbar
    fi
}

# ---------------------------------------------------------
# Configuration & Geocoding
# ---------------------------------------------------------
search_location() {
    search_term="$1"
    results=$(curl -s -A "PMT2e-Weather-Agent" \
        "https://nominatim.openstreetmap.org/search?q=${search_term}&format=json&limit=5")

    if [ -z "$results" ] || [ "$results" = "[]" ]; then
        return 1
    fi
    printf '%s' "$results" | jq -r '.[] | "\(.lat)|\(.lon)|\(.display_name)"'
}

do_config() {
    if [ -f "$config_file" ]; then
        . "$config_file"
    fi

    while true; do
        new_configs=$(yad --title="Weather Settings" \
            --window-icon="${iconpath}/cloudy.svg" \
            --form --columns=2 \
            --field="City/Location:" "${location}" \
            --field="Temp Unit:CB" "${temp_unit:-celsius}!celsius!fahrenheit" \
            --field="Icon Style:CB" "${icon_type:-coloured}!coloured!monochrome" \
            --field='!gtk-find!Search':BTN "sh -c 'exit 0'" \
            --field='!gtk-help!Location':BTN "yad --info --text='Enter city and Search. Pick from list.' --borders=15" \
            --button="Save:0" --button="Cancel:1" \
            --borders=15)

        if [ $? -ne 0 ]; then
            break
        fi

        loc=$(printf '%s' "$new_configs" | cut -d'|' -f1)
        t_unit=$(printf '%s' "$new_configs" | cut -d'|' -f2)
        i_style=$(printf '%s' "$new_configs" | cut -d'|' -f3)

        search_results=$(search_location "$loc")
        if [ $? -ne 0 ]; then
            yad --error --text="Location not found." --borders=15
            continue
        fi

        selection=$(printf '%s' "$search_results" | yad --list \
            --title="Select Exact Location" \
            --column="Lat" --column="Lon" --column="Address" \
            --width=750 --height=350 --borders=15)

        if [ $? -eq 0 ] && [ -n "$selection" ]; then
            lat=$(printf '%s' "$selection" | cut -d'|' -f1)
            lon=$(printf '%s' "$selection" | cut -d'|' -f2)

            mkdir -p "$config_dir"
            cat <<EOF > "$config_file"
latitude="$lat"
longitude="$lon"
location="$loc"
temp_unit="$t_unit"
icon_type="$i_style"
waybar_signal="${waybar_signal}"
sfwbar_signal="${sfwbar_signal}"
EOF
            yad --info --text="Saved: $loc" --borders=15
            send_refresh_signals
            break
        fi
    done
}

# ---------------------------------------------------------
# Weather Engine & Translation
# ---------------------------------------------------------
get_info_by_code() {
    code="$1"
    day_state="$2"

    case "$code" in
        0|1)
            cat="clear"
            glyph="󰖙"
            if [ "$day_state" = "1" ]; then
                icon="clear-day.svg"
            else
                icon="clear-night.svg"
            fi
            ;;
        2|3)
            cat="cloudy"
            glyph="󰖐"
            if [ "$day_state" = "1" ]; then
                icon="cloudy-2-day.svg"
            else
                icon="cloudy-2-night.svg"
            fi
            ;;
        45|48)
            cat="fog"
            glyph="󰖑"
            icon="fog.svg"
            ;;
        51|53|55|56|57)
            cat="drizzle"
            glyph="󰖗"
            icon="rainy-1.svg"
            ;;
        61|63|65|66|67|80|81|82)
            cat="rain"
            glyph="󰖖"
            icon="rainy-3.svg"
            ;;
        71|73|75|77|85|86)
            cat="snow"
            glyph="󰖘"
            icon="snowy-3.svg"
            ;;
        95|96|99)
            cat="thunder"
            glyph="󰖓"
            icon="thunder.svg"
            ;;
        *)
            cat="unknown"
            glyph="󰨹"
            icon="default-no.svg"
            ;;
    esac

    if [ -f "$translation_file" ]; then
        desc=$(jq -r ".\"$cat\".$sys_lang // .\"$cat\".en" "$translation_file")
    else
        desc="$cat"
    fi

    echo "$icon|$glyph|$desc"
}

# ---------------------------------------------------------
# Execution Logic
# ---------------------------------------------------------
action=""
output_format="icon"

while getopts ":nFmtgich" opt; do
    case ${opt} in
        h) show_help ;;
        n) action="notify" ;;
        F) action="forecast" ;;
        c) action="config" ;;
        m) action="menu" ;;
        t) output_format="text" ;;
        g) output_format="glyph" ;;
        i) output_format="icon" ;;
        *) die "Argument error. Use -h for help." ;;
    esac
done

if [ -f "$config_file" ]; then
    . "$config_file"
else
    if [ "$action" != "config" ] && [ "$action" != "menu" ]; then
        do_config
        if [ -f "$config_file" ]; then
            . "$config_file"
        else
            exit 1
        fi
    fi
fi

# Load UI Labels from JSON
if [ -f "$translation_file" ]; then
    lbl_date=$(jq -r ".labels.date.$sys_lang // .labels.date.en" "$translation_file")
    lbl_stat=$(jq -r ".labels.status.$sys_lang // .labels.status.en" "$translation_file")
    lbl_temp=$(jq -r ".labels.temp.$sys_lang // .labels.temp.en" "$translation_file")
    lbl_hum=$(jq -r ".labels.humidity.$sys_lang // .labels.humidity.en" "$translation_file")
    lbl_wind=$(jq -r ".labels.wind.$sys_lang // .labels.wind.en" "$translation_file")
    lbl_prec=$(jq -r ".labels.rain_prob.$sys_lang // .labels.rain_prob.en" "$translation_file")
    lbl_title=$(jq -r ".labels.forecast_title.$sys_lang // .labels.forecast_title.en" "$translation_file")
else
    lbl_date="Date"; lbl_stat="Status"; lbl_temp="Temp"; lbl_hum="Humidity"
    lbl_wind="Wind"; lbl_prec="Rain Prob."; lbl_title="Weather Forecast"
fi

case "$action" in
    config)
        do_config
        ;;
    menu)
        printf "Show Forecast,%s -F\nNotification Info,%s -n\nSettings,%s -c\n" "$scriptname" "$scriptname" "$scriptname" | createjgmenu
        ;;
    forecast|notify|"")
        if [ -z "$latitude" ]; then
            die "Incomplete configuration. Run pmweather -c first." "-y"
        fi

        weather_data=$(curl -s "https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m,is_day,precipitation&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max&temperature_unit=${temp_unit}&timezone=auto&forecast_days=3")

        if [ -z "$weather_data" ]; then
            die "Error: Unable to connect to weather API." "-y"
        fi

        if [ "$action" = "forecast" ]; then
            (
                i=0
                while [ $i -le 2 ]; do
                    f_date=$(printf '%s' "$weather_data" | jq -r ".daily.time[$i]")
                    f_max=$(printf '%s' "$weather_data" | jq -r ".daily.temperature_2m_max[$i]")
                    f_min=$(printf '%s' "$weather_data" | jq -r ".daily.temperature_2m_min[$i]")
                    f_code=$(printf '%s' "$weather_data" | jq -r ".daily.weather_code[$i]")
                    f_prec=$(printf '%s' "$weather_data" | jq -r ".daily.precipitation_probability_max[$i]")

                    f_info=$(get_info_by_code "$f_code" "1")
                    f_icon_file=$(printf '%s' "$f_info" | cut -d'|' -f1)
                    f_desc=$(printf '%s' "$f_info" | cut -d'|' -f3)

                    sub_dir=""
                    if [ "$icon_type" = "monochrome" ]; then
                        sub_dir="dark/"
                    fi

                    full_icon_path="${iconpath}/${sub_dir}${f_icon_file}"

                    printf '%s\n' "$full_icon_path"
                    printf '%s\n' "$f_date"
                    printf '%s\n' "$f_desc"
                    printf '%s / %s°\n' "$f_min" "$f_max"
                    printf '%s%%\n' "$f_prec"
                    i=$((i + 1))
                done
            ) | yad --list --title="${lbl_title}: ${location}" \
                --width=650 --height=400 --borders=15 \
                --column="":IMG --column="${lbl_date}" --column="${lbl_stat}" --column="${lbl_temp} Min/Max" --column="${lbl_prec}" \
                --no-selection --button="Close:0"
        else
            curr_code=$(printf '%s' "$weather_data" | jq -r '.current.weather_code')
            curr_is_day=$(printf '%s' "$weather_data" | jq -r '.current.is_day')

            info_str=$(get_info_by_code "$curr_code" "$curr_is_day")
            icon_file=$(printf '%s' "$info_str" | cut -d'|' -f1)
            glyph=$(printf '%s' "$info_str" | cut -d'|' -f2)
            desc=$(printf '%s' "$info_str" | cut -d'|' -f3)

            if [ "$action" = "notify" ]; then
                curr_temp=$(printf '%s' "$weather_data" | jq -r '.current.temperature_2m')
                curr_hum=$(printf '%s' "$weather_data" | jq -r '.current.relative_humidity_2m')
                curr_wind=$(printf '%s' "$weather_data" | jq -r '.current.wind_speed_10m')

                dunstify -i "${iconpath}/${icon_file}" "Weather: ${location}" \
                    "${lbl_temp}: ${curr_temp}° (${desc})\n${lbl_hum}: ${curr_hum}%\n${lbl_wind}: ${curr_wind} km/h"
            else
                case "$output_format" in
                    text)  printf '%s\n' "$desc" ;;
                    glyph) printf '%s\n' "$glyph" ;;
                    icon)
                        sub=""
                        if [ "$icon_type" = "monochrome" ]; then
                            sub="dark/"
                        fi
                        printf '%s/%s%s\n' "$iconpath" "$sub" "$icon_file"
                        ;;
                esac
            fi
        fi
        ;;
esac
