#!/bin/sh
# ==============================================================================
# Script Name  : pmdesktop
# Description  : PMT2e Desktop Agent - X11 Workspace and Window Manager
# Author       : Max Franco <purpleleaf at ganoia.eu>
# License      : GPL-3.0
# Dependencies : xdotool, wmctrl, createjgmenu
# ==============================================================================

iconpath="/usr/share/pmt2e/icons"
scriptname=$(basename "$0")

# ---------------------------------------------------------
# Error handling & Utilities
# ---------------------------------------------------------
exists() { command -v "$1" >/dev/null 2>&1; }

die() {
    printf '%s\n' "$*" 1>&2
    exit 1
}

show_help() {
    cat << EOF
Usage: $scriptname [Action] | [Output]

PMT2e Desktop Agent - Manage workspaces and move windows.

ACTIONS (Choose one):
  -n    Switch to NEXT desktop
  -p    Switch to PREVIOUS desktop
  -m    Show Desktop Selection Menu (jgmenu)
  -r    Show "Move Windows To" Menu (jgmenu)
  -w S D Move all windows from Source (S) to Destination (D)
  -h    Show this help message and exit

OUTPUT FORMATS (For status bars):
  -t    Print text output (e.g., 'Desk: 1')
  -f    Print Nerd Font glyph (workspace aware)
  -i    Print path to desktop SVG icon

Examples:
  $scriptname -n       # Go to next desktop
  $scriptname -t       # Print current desktop number
EOF
}

# ---------------------------------------------------------
# Action Handlers
# ---------------------------------------------------------

do_move_windows() {
    src="$1"
    dst="$2"
    [ -z "$src" ] || [ -z "$dst" ] && die "Action -w requires <source> and <destination> desktop IDs."

    # Process window list line-by-line
    wmctrl -l | while IFS= read -r line; do
        set -- $line
        winid="$1"
        desk="$2"
        [ -n "$winid" ] || continue

        if [ "$desk" = "$src" ]; then
            if exists xdotool; then
                xdotool set_desktop_for_window "$winid" "$dst"
            else
                wmctrl -i -r "$winid" -t "$dst"
            fi
        fi
    done

    # Switch to destination
    xdotool set_desktop "$dst"
}

do_menu() {
    num_desks=$(xdotool get_num_desktops 2>/dev/null)
    [ -n "$num_desks" ] || die "Failed to get desktop count."

    set --
    i=1
    while [ "$i" -le "$num_desks" ]; do
        target=$((i - 1))
        set -- "$@" "Desktop $i,xdotool set_desktop $target"
        i=$((i + 1))
    done
    createjgmenu "^sep(Switch to:)" "$@"
}

do_move_menu() {
    num_desks=$(xdotool get_num_desktops 2>/dev/null)
    curr_desk=$(xdotool get_desktop 2>/dev/null)

    # Check if windows exist on current desk using POSIX awk
    win_on_desk=$(wmctrl -l | awk -v d="$curr_desk" '$2 == d {print $1; exit}')

    if [ -n "$win_on_desk" ]; then
        set --
        i=1
        while [ "$i" -le "$num_desks" ]; do
            target=$((i - 1))
            if [ "$target" -ne "$curr_desk" ]; then
                # Build command to move windows
                cmd="$scriptname -w $curr_desk $target"
                set -- "$@" "To Desktop $i,$cmd"
            fi
            i=$((i + 1))
        done
        createjgmenu "^sep(Move Windows To:)" "$@"
    else
        createjgmenu "^sep(No windows to move)"
    fi
}

# ---------------------------------------------------------
# Execution & Argument Parsing
# ---------------------------------------------------------

exists xdotool || die "xdotool is required but not found."

action=""
output_format=""

while getopts ":hnprmiwft" opt; do
    case ${opt} in
        h) show_help; exit 0 ;;
        n) action="next" ;;
        p) action="prev" ;;
        m) action="menu" ;;
        r) action="move_menu" ;;
        w) action="windows" ;;
        i) output_format="icon" ;;
        f) output_format="glyph" ;;
        t) output_format="text" ;;
        \?|*) die "Invalid option. Use -h for help." ;;
    esac
done

# Action Logic
if [ -n "$action" ]; then
    case "$action" in
        next)      xdotool set_desktop --relative 1 ;;
        prev)      xdotool set_desktop --relative -- -1 ;;
        menu)      do_menu ;;
        move_menu) do_move_menu ;;
        windows)   
            shift $((OPTIND - 1))
            do_move_windows "$1" "$2" 
            ;;
    esac
    exit 0
fi

# Output Logic
if [ -n "$output_format" ]; then
    curr_num=$(( $(xdotool get_desktop) + 1 ))
    case "$output_format" in
        text)  printf 'Desk: %s\n' "$curr_num" ;;
        glyph) printf '󰍺 <span font-size="xx-small">%s</span>\n' "$curr_num" ;;
        icon)  printf '%s/desktop.svg\n%s\n' "$iconpath" "$curr_num" ;;
    esac
    exit 0
fi

# Fallback
show_help
